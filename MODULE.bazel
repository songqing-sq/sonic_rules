# A repo-root copy of config.h. mke2fs links @libarchive, whose transitive xz
# (liblzma) dep exports its OWN config.h on a -I path. For the misc/ sources
# (mke2fs.c etc.) that would shadow our lib/config.h (exported on the
# lower-priority -isystem path from includes=["lib"]), leaving HAVE_* /
# ROOT_SYSCONFDIR undefined. Placing config.h at the repo root makes Bazel's
# automatic -iquote (repo genfiles root) resolve `#include "config.h"` to ours
# first -- -iquote outranks -I for quoted includes. Only fed to :mke2fs.
genrule(
    name = "config_h_root",
    srcs = [":config_h"],
    outs = ["config.h"],
    cmd = "cp $< $@",
)

# lib/ext2fs/ext2_types.h, lib/blkid/blkid_types.h, lib/uuid/uuid_types.h:
# the autoconf substitutes SIZEOF_{SHORT,INT,LONG,LONG_LONG} into the .in
# templates. Result is constant for ILP32/LP64 glibc and identical to what
# `./configure` emits here; copy in directly to keep the awk-substitute step
# out of the build graph.
genrule(
    name = "ext2_types_h",
    outs = ["lib/ext2fs/ext2_types.h"],
    cmd = '''cat > $@ <<'EOF'
#if (!defined(_LINUX_TYPES_H) && !defined(_BLKID_TYPES_H) && \\\\
    !defined(_EXT2_TYPES_H))
#define _EXT2_TYPES_H
typedef __signed__ char  __s8;
typedef unsigned char    __u8;
typedef __signed__ short __s16;
typedef unsigned short   __u16;
typedef __signed__ int   __s32;
typedef unsigned int     __u32;
typedef __signed__ long long __s64;
typedef unsigned long long   __u64;
#define HAVE___U8
#define HAVE___S8
#define HAVE___U16
#define HAVE___S16
#define HAVE___U32
#define HAVE___S32
#define HAVE___U64
#define HAVE___S64
#endif

#include <stdint.h>

#ifndef EXT2_ENDIAN_H_
#define EXT2_ENDIAN_H_
#ifndef __bitwise
# define __bitwise
#endif
#define __force
typedef __u16 __bitwise __le16;
typedef __u32 __bitwise __le32;
typedef __u64 __bitwise __le64;
typedef __u16 __bitwise __be16;
typedef __u32 __bitwise __be32;
typedef __u64 __bitwise __be64;
#endif

#define HAVE_SYS_TYPES_H 1
#undef WORDS_BIGENDIAN
EOF''',
)

genrule(
    name = "blkid_types_h",
    outs = ["lib/blkid/blkid_types.h"],
    cmd = '''cat > $@ <<'EOF'
#if (!defined(_LINUX_TYPES_H) && !defined(_BLKID_TYPES_H) && \\\\
    !defined(_EXT2_TYPES_H))
#define _BLKID_TYPES_H
typedef __signed__ char  __s8;
typedef unsigned char    __u8;
typedef __signed__ short __s16;
typedef unsigned short   __u16;
typedef __signed__ int   __s32;
typedef unsigned int     __u32;
typedef __signed__ long long __s64;
typedef unsigned long long   __u64;
#define HAVE___U8
#define HAVE___S8
#define HAVE___U16
#define HAVE___S16
#define HAVE___U32
#define HAVE___S32
#define HAVE___U64
#define HAVE___S64
#endif
EOF''',
)

genrule(
    name = "uuid_types_h",
    outs = ["lib/uuid/uuid_types.h"],
    cmd = '''cat > $@ <<'EOF'
#if (!defined(_STDINT_H) && !defined(_UUID_STDINT_H))
#define _UUID_STDINT_H
#include <stdint.h>
#endif
EOF''',
)

# uuid.h / blkid.h: the autoconf rule is literally `cp foo.h.in foo.h` (no
# substitutions). Bazel genrule does the same.
genrule(
    name = "uuid_h",
    srcs = ["lib/uuid/uuid.h.in"],
    outs = ["lib/uuid/uuid.h"],
    cmd = "cp $< $@",
)

genrule(
    name = "blkid_h",
    srcs = ["lib/blkid/blkid.h.in"],
    outs = ["lib/blkid/blkid.h"],
    cmd = "cp $< $@",
)

# compile_et output: ext2_err.{c,h} / prof_err.{c,h}. Mirrors compile_et.sh,
# which is a thin awk wrapper. ext2_err.et.in has a single @E2FSPROGS_VERSION@
# substitution; prof_err.et has none.
# crc32c_table.h: emitted by gen_crc32ctable, a tiny host program that
# computes the polynomial division table at build time (faster + smaller
# binary than computing at runtime). Built as an exec-config cc_binary and
# run from a genrule, mirroring the upstream Makefile.
cc_binary(
    name = "gen_crc32ctable",
    srcs = [
        "lib/ext2fs/crc32c_defs.h",
        "lib/ext2fs/gen_crc32ctable.c",
    ],
    visibility = ["//visibility:private"],
)

genrule(
    name = "crc32c_table_h",
    outs = ["lib/ext2fs/crc32c_table.h"],
    cmd = "$(execpath :gen_crc32ctable) > $@",
    tools = [":gen_crc32ctable"],
)

genrule(
    name = "ext2_err_et",
    srcs = ["lib/ext2fs/ext2_err.et.in"],
    outs = ["lib/ext2fs/ext2_err.et"],
    cmd = "sed 's/@E2FSPROGS_VERSION@/1.47.2/g' $< > $@",
)

genrule(
    name = "ext2_err_h",
    srcs = [":ext2_err_et", "lib/et/et_h.awk"],
    outs = ["lib/ext2fs/ext2_err.h"],
    cmd = "awk -f $(execpath lib/et/et_h.awk) outfile=$@ outfn=ext2_err.h $(execpath :ext2_err_et)",
)

genrule(
    name = "ext2_err_c",
    srcs = [":ext2_err_et", "lib/et/et_c.awk"],
    outs = ["lib/ext2fs/ext2_err.c"],
    cmd = "awk -f $(execpath lib/et/et_c.awk) outfile=$@ outfn=ext2_err.c $(execpath :ext2_err_et)",
)

genrule(
    name = "prof_err_h",
    srcs = ["lib/support/prof_err.et", "lib/et/et_h.awk"],
    outs = ["lib/support/prof_err.h"],
    cmd = "awk -f $(execpath lib/et/et_h.awk) outfile=$@ outfn=prof_err.h $(execpath lib/support/prof_err.et)",
)

genrule(
    name = "prof_err_c",
    srcs = ["lib/support/prof_err.et", "lib/et/et_c.awk"],
    outs = ["lib/support/prof_err.c"],
    cmd = "awk -f $(execpath lib/et/et_c.awk) outfile=$@ outfn=prof_err.c $(execpath lib/support/prof_err.et)",
)

# misc/default_profile.c: profile-to-c.awk wraps mke2fs.conf into a single
# const char* string. mke2fs.conf has no autoconf substitutions; cp suffices.
genrule(
    name = "default_profile_c",
    srcs = ["misc/mke2fs.conf.in", "misc/profile-to-c.awk"],
    outs = ["misc/default_profile.c"],
    cmd = "awk -f $(execpath misc/profile-to-c.awk) < $(execpath misc/mke2fs.conf.in) > $@",
)

# -------- cc_library targets -------------------------------------------------

# Common copts for every C compile: enable HAVE_CONFIG_H and silence the
# warning-as-error noise upstream is tolerant of (unused params, sign cmp).
COMMON_COPTS = [
    "-DHAVE_CONFIG_H",
    "-D_GNU_SOURCE",
    "-Wno-unused-parameter",
    "-Wno-sign-compare",
    "-Wno-implicit-fallthrough",
    "-Wno-stringop-truncation",
    "-Wno-format-truncation",
    "-Wno-unused-result",
    "-Wno-unused-but-set-variable",
    "-Wno-deprecated-declarations",
    "-Wno-address-of-packed-member",
    "-Wno-missing-field-initializers",
]

# Aggregated public-facing headers from libext2fs / libet / libsupport.
# Several downstream headers (e.g. lib/e2p/e2p.h) #include <ext2fs/ext2_fs.h>
# and "support/quotaio.h" even though they don't link those libs, so a
