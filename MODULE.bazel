    uris = ["https://sonic-build.alibaba-inc.com/debian_snapshot/20260410"],
)
apt.sources_list(
    architectures = ["amd64"],
    components = ["main"],
    suites = ["bookworm-security"],
    uris = ["https://sonic-build.alibaba-inc.com/debian_snapshot/20260410"],
)
apt.install(
    dependency_set = "sysroot-bookworm",
    packages = [
        "libc6-dev",
        #"libgcc-12-dev",
        #"libstdc++-12-dev",
        "libstdc++6",
        "linux-libc-dev",

# pip hub for build-time Python tools (e.g. the jinja2 renderer). Declared in
# this module so targets under @sonic_build_infra can depend on @pip_tools//...
# without relying on the root module's separate "pip" hub, which is not visible
# here. Uses the same aspect_rules_py uv extension as docker-base-bookworm.
uv = use_extension("@aspect_rules_py//uv/unstable:extension.bzl", "uv")
uv.declare_hub(hub_name = "pip_tools")
uv.declare_venv(
    hub_name = "pip_tools",
    venv_name = "default",
        # Go/Gazelle does not let us inject cgo deps in a clean way.
        # So we have to inject these deps into every c compilation.
        # https://github.com/bazel-contrib/bazel-gazelle/issues/1543
        # https://github.com/bazel-contrib/bazel-gazelle/issues/2261
        # TODO:  add here libpam0g
    ],
    suites = [
        "bookworm",
        "bookworm-updates",
        "bookworm-security",
    ],
)
)
uv.lockfile(
    src = "//jinja2:uv.lock",
    hub_name = "pip_tools",
    venv_name = "default",
)

# Build-time pyang (YANG codegen) runner. Separate venv on the same pip_tools
# hub so @sonic_build_infra//pyang:pyang can depend on @pip_tools//pyang.
uv.declare_venv(
    hub_name = "pip_tools",
    venv_name = "pyang",
)
uv.lockfile(
    src = "//pyang:uv.lock",
    hub_name = "pip_tools",
    venv_name = "pyang",
)
use_repo(uv, "pip_tools")
use_repo(apt, "sysroot-bookworm")
