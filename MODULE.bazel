# -------- mke2fs cc_binary ---------------------------------------------------
#
# default_profile.c is generated above from mke2fs.conf.in by profile-to-c.awk.
# mke2fs is statically linked against the e2fsprogs private libs; pthread comes
# from :ext2fs (propagated via linkopts).
cc_binary(
    name = "mke2fs",
    srcs = [
        "misc/create_inode.c",
        "misc/create_inode.h",
        # mke2fs -d <tarball>: libarchive-backed populate-from-tar (1.47.1+).
        "misc/create_inode_libarchive.c",
        "misc/create_inode_libarchive.h",
        "misc/mk_hugefiles.c",
        "misc/mke2fs.c",
        "misc/mke2fs.h",
        "misc/util.c",
        "misc/util.h",
        ":default_profile_c",
        # Repo-root config.h: wins the `#include "config.h"` lookup over the xz
        # config.h that @libarchive drags in transitively (see :config_h_root).
        ":config_h_root",
        "version.h",
    ],
    copts = COMMON_COPTS + [
        # misc/Makefile sets root_sbindir=/sbin via configure; the only place
        # mke2fs.c uses ROOT_SBINDIR is to spawn fsck. Hard-coded here.
        '-DROOT_SBINDIR=\\\\"/sbin\\\\"',
    ],
    includes = ["lib"],
    visibility = ["//visibility:public"],
    deps = [
        ":blkid",
        ":e2p",
        ":et",
        ":ext2fs",
        ":support",
        ":uuid",
        "@libarchive//libarchive:archive",  # mke2fs -d <tarball> reader
    ],
)

# -------- libss + debugfs ----------------------------------------------------
#
# debugfs is the interactive ext2/3/4 editor. It drives the subsystem library
# (lib/ss, libss) for its command tables and links the same private e2fsprogs
# libs as mke2fs. The command tables (debug_cmds / extent_cmds / ro_debug_cmds)
# are generated from .ct files by mk_cmds (sed ct_c.sed | awk ct_c.awk); the
# ss error table is generated from ss_err.et by the same et_h/et_c awk scripts
# used for ext2_err. Journal-recovery support pulls in e2fsck/revoke.c and
# e2fsck/recovery.c; -DDEBUGFS selects the debugfs branch of jfs_user.h.

# ss error table: ss_err.et has no @VERSION@ substitution, so feed it directly
# to et_h.awk / et_c.awk (mirrors :ext2_err_h / :ext2_err_c).
genrule(
    name = "ss_err_h",
    srcs = ["lib/ss/ss_err.et", "lib/et/et_h.awk"],
    outs = ["lib/ss/ss_err.h"],
    cmd = "awk -f $(execpath lib/et/et_h.awk) outfile=$@ outfn=ss_err.h $(execpath lib/ss/ss_err.et)",
)

genrule(
    name = "ss_err_c",
    srcs = ["lib/ss/ss_err.et", "lib/et/et_c.awk"],
    outs = ["lib/ss/ss_err.c"],
    cmd = "awk -f $(execpath lib/et/et_c.awk) outfile=$@ outfn=ss_err.c $(execpath lib/ss/ss_err.et)",
)

# std_rqs.c defines ss_std_requests (the built-in help/list/quit commands).
# Generated from std_rqs.ct by mk_cmds, same recipe as the debugfs tables.
genrule(
    name = "std_rqs_c",
    srcs = [
        "lib/ss/std_rqs.ct",
        "lib/ss/ct_c.sed",
        "lib/ss/ct_c.awk",
    ],
    outs = ["lib/ss/std_rqs.c"],
    cmd = (
        "sed -f $(execpath lib/ss/ct_c.sed) $(execpath lib/ss/std_rqs.ct) | " +
        "awk -f $(execpath lib/ss/ct_c.awk) rootname=lib/ss/std_rqs outfile=$@ -"
    ),
)

# lib/ss: the subsystem (command-line dispatch) library. Built without
# readline; get_readline.c uses dlopen()/dlsym() to load libreadline at
# runtime if SS_READLINE_PATH points at one, so the only link requirement is
# -ldl. ss.h does #include <ss/ss_err.h>, resolved via -Ilib (from deps).
cc_library(
    name = "ss",
    srcs = [
        "lib/ss/data.c",
        "lib/ss/error.c",
        "lib/ss/execute_cmd.c",
        "lib/ss/get_readline.c",
        "lib/ss/help.c",
        "lib/ss/invocation.c",
        "lib/ss/list_rqs.c",
        "lib/ss/listen.c",
        "lib/ss/pager.c",
        "lib/ss/parse.c",
        "lib/ss/prompt.c",
        "lib/ss/request_tbl.c",
        "lib/ss/requests.c",
        ":ss_err_c",
        ":std_rqs_c",
        "lib/ss/ss_internal.h",
        "lib/ss/mit-sipb-copyright.h",
        ":config_h",
        ":dirpaths_h",
    ],
    hdrs = ["lib/ss/ss.h", ":ss_err_h"],
    copts = COMMON_COPTS,
    includes = ["lib", "lib/ss"],
    linkopts = ["-ldl"],
    linkstatic = True,
    visibility = ["//visibility:public"],
    deps = [":et", ":public_headers"],
)

# mk_cmds codegen for debugfs's three command tables. rootname is the .ct path
# without the extension (e.g. debugfs/debug_cmds), matching mk_cmds.sh.in:
#   sed -f ct_c.sed FILE.ct | awk -f ct_c.awk rootname=ROOT outfile=OUT -
# The generated .c files go under debugfs_gen/ rather than debugfs/ so the
# cc_binary's `debugfs` output path does not collide with a debugfs/ output
# subtree (Bazel forbids one output path being a prefix of another).
[
    genrule(
        name = ct + "_c",
        srcs = [
            "debugfs/" + ct + ".ct",
            "lib/ss/ct_c.sed",
            "lib/ss/ct_c.awk",
        ],
        outs = ["debugfs_gen/" + ct + ".c"],
        cmd = (
            "sed -f $(execpath lib/ss/ct_c.sed) $(execpath debugfs/" + ct + ".ct) | " +
            "awk -f $(execpath lib/ss/ct_c.awk) rootname=debugfs/" + ct +
            " outfile=$@ -"
        ),
    )
    for ct in ["debug_cmds", "extent_cmds", "ro_debug_cmds"]
]

# debugfs cc_binary. DEBUG_OBJS from debugfs/Makefile.in, plus the generated
# command tables and the e2fsck journal-recovery sources. LOCAL_CFLAGS in the
# upstream Makefile are `-I../e2fsck -DDEBUGFS`; -Ie2fsck is supplied via copts
# and -Idebugfs lets the e2fsck sources find debugfs/journal.h.
cc_binary(
    name = "debugfs",
    srcs = [
        "debugfs/debugfs.c",
        "debugfs/util.c",
        "debugfs/ls.c",
        "debugfs/ncheck.c",
        "debugfs/icheck.c",
        "debugfs/lsdel.c",
        "debugfs/dump.c",
        "debugfs/set_fields.c",
        "debugfs/logdump.c",
        "debugfs/htree.c",
        "debugfs/unused.c",
        "debugfs/extent_inode.c",
        "debugfs/zap.c",
        "debugfs/filefrag.c",
        "debugfs/journal.c",
        "debugfs/do_journal.c",
        "debugfs/xattrs.c",
        "debugfs/quota.c",
        "debugfs/do_orphan.c",  # new in 1.47.2: do_orphan_inodes (debug_cmds)
        "misc/create_inode.c",
        # create_inode.c #includes create_inode_libarchive.h and references
        # __populate_fs_from_tar (1.47.1+); link the libarchive tar reader, same
        # as :mke2fs. debugfs itself never ingests a tarball, but the symbol must
        # resolve.
        "misc/create_inode_libarchive.c",
        "misc/create_inode_libarchive.h",
        "misc/e2freefrag.c",
        "e2fsck/revoke.c",
        "e2fsck/recovery.c",
        # debug_cmds + extent_cmds are the two tables linked into the
        # read-write debugfs (DEBUG_OBJS in debugfs/Makefile.in). ro_debug_cmds
        # also declares `command_table debug_cmds`, so it must NOT be linked
        # here (it belongs to the separate read-only rdebugfs binary); linking
        # it would duplicate the debug_cmds symbol.
        ":debug_cmds_c",
        ":extent_cmds_c",
        # headers
        "debugfs/debugfs.h",
        "debugfs/journal.h",
        "misc/create_inode.h",
        "misc/e2freefrag.h",
        "e2fsck/jfs_user.h",
        "version.h",
        ":config_h",
        # Repo-root config.h: wins `#include "config.h"` over the xz config.h
        # that @libarchive drags in transitively (see :config_h_root).
        ":config_h_root",
        ":dirpaths_h",
    ],
    copts = COMMON_COPTS + ["-DDEBUGFS"],
    includes = ["lib", "debugfs", "e2fsck"],
    visibility = ["//visibility:public"],
    deps = [
        ":ss",
        ":ext2fs",
        ":e2p",
        ":blkid",
        ":support",
        ":uuid",
        ":et",
        ":public_headers",
        "@libarchive//libarchive:archive",  # __populate_fs_from_tar reader
    ],
)
""",
    sha256 = "be7edd7031734d1fef8a319f0901828f8ab89e8f3b5073e6b18740be3771a95c",
    strip_prefix = "e2fsprogs-1.47.2",
    urls = ["https://github.com/tytso/e2fsprogs/archive/refs/tags/v1.47.2.tar.gz"],
)

