# ----------------------------------------------------------------------------
# Hermetic mksquashfs/unsquashfs build tools (squashfs/tools).
#
# mksquashfs is not on the host PATH, so it is built from source as native
# Bazel cc_binary targets (no rules_foreign_cc). squashfs-tools has no autoconf
# — its plain Makefile is driven entirely by -D flags, so no config.h is needed;
# the cc_binary copts below reproduce the Makefile's CFLAGS for GZIP_SUPPORT=1
# ZSTD_SUPPORT=1 (XZ/LZO/LZ4 off). The legacy build invokes
# `mksquashfs ... -comp zstd -b 1M`, so zstd (and the default gzip) compressors
# must be linked in: libz is @zlib_src//:z and libzstd is @zstd_src//:zstd,
# both already declared below as native cc_library deps.
# ----------------------------------------------------------------------------
http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")
http_file = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_file")

# ONIE recovery ISO consumed by //disk_image:onie_iso_extract to produce
# MBR / GRUB core.img / ONIE-BOOT staging tar for sonic-vs.img.gz. Mirrors
# the same http_file in the root MODULE.bazel (Bzlmod repos declared in
# the root are not visible to dependency modules, so this module declares
# its own; the matching sha256 lets Bazel share the content-addressable
# download cache entry).
http_file(
    name = "onie_recovery_kvm_x86_64",
    urls = ["https://packages.trafficmanager.net/public/onie/onie-recovery-x86_64-kvm_x86_64-r0.iso"],
    sha256 = "c88597f5ce8c7abc2d442721f173c19633e808d6f12b9ae9ac35dd9b5e72ee8a",
    downloaded_file_path = "onie-recovery-x86_64-kvm_x86_64-r0.iso",
)

http_archive(
    name = "squashfs_src",
    build_file_content = """
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")

# CFLAGS reproduced from squashfs-tools/Makefile for the legacy SONiC build
# options: GZIP_SUPPORT=1 ZSTD_SUPPORT=1 (XZ/LZO/LZ4/LZMA off), XATTR_SUPPORT=1
# XATTR_DEFAULT=1 REPRODUCIBLE_DEFAULT=1, COMP_DEFAULT=gzip. VERSION/DATE/YEAR
# come from RELEASE_VERSION/RELEASE_DATE in the Makefile (4.6.1, 2023/03/25).
SQUASHFS_COPTS = [
    "-D_FILE_OFFSET_BITS=64",
    "-D_LARGEFILE_SOURCE",
    "-D_GNU_SOURCE",
    '-DCOMP_DEFAULT=\\\\"gzip\\\\"',
    "-DGZIP_SUPPORT",
    "-DZSTD_SUPPORT",
    "-DXATTR_SUPPORT",
    "-DXATTR_DEFAULT",
    "-DREPRODUCIBLE_DEFAULT",
    '-DVERSION=\\\\"4.6.1\\\\"',
    '-DDATE=\\\\"2023/03/25\\\\"',
    '-DYEAR=\\\\"2023\\\\"',
    "-Wno-unused-result",
]

# All in-tree headers; the Makefile's per-object header deps mean every TU may
# pull any of these via "-I.". Hand them to both binaries to keep srcs minimal.
SQUASHFS_HDRS = glob(["*.h"])

# MKSQUASHFS_OBJS (Makefile L209) + gzip_wrapper (L225) + zstd_wrapper (L275)
# + xattr.o read_xattrs.o tar_xattr.o pseudo_xattr.o (L287).
cc_binary(
    name = "mksquashfs",
    srcs = [
        "mksquashfs.c",
        "read_fs.c",
        "action.c",
        "swap.c",
        "pseudo.c",
        "compressor.c",
        "sort.c",
        "progressbar.c",
        "info.c",
        "restore.c",
        "process_fragments.c",
        "caches-queues-lists.c",
        "reader.c",
        "tar.c",
        "date.c",
        "gzip_wrapper.c",
        "zstd_wrapper.c",
        "xattr.c",
        "read_xattrs.c",
        "tar_xattr.c",
        "pseudo_xattr.c",
    ] + SQUASHFS_HDRS,
    copts = SQUASHFS_COPTS,
    includes = ["."],
    linkopts = [
        "-pthread",
        "-lm",
    ],
    linkstatic = True,
    visibility = ["//visibility:public"],
    deps = [
        "@zlib_src//:z",
        "@zstd_src//:zstd",
    ],
)

# UNSQUASHFS_OBJS (Makefile L213) + gzip_wrapper (L226) + zstd_wrapper (L276)
# + read_xattrs.o unsquashfs_xattr.o (L288).
cc_binary(
    name = "unsquashfs",
    srcs = [
        "unsquashfs.c",
        "unsquash-1.c",
        "unsquash-2.c",
        "unsquash-3.c",
        "unsquash-4.c",
        "unsquash-123.c",
        "unsquash-34.c",
        "unsquash-1234.c",
        "unsquash-12.c",
        "swap.c",
        "compressor.c",
        "unsquashfs_info.c",
        "date.c",
        "gzip_wrapper.c",
        "zstd_wrapper.c",
        "read_xattrs.c",
        "unsquashfs_xattr.c",
    ] + SQUASHFS_HDRS,
    copts = SQUASHFS_COPTS,
    includes = ["."],
    linkopts = [
        "-pthread",
        "-lm",
    ],
    linkstatic = True,
    visibility = ["//visibility:public"],
    deps = [
        "@zlib_src//:z",
        "@zstd_src//:zstd",
    ],
)
""",
    sha256 = "9c4974e07c61547dae14af4ed1f358b7d04618ae194e54d6be72ee126f0d2f53",
    # strip to the squashfs-tools/ subdir so the .c/.h sources are at the
    # repo root (matching the "-I." include the Makefile uses).
    strip_prefix = "squashfs-tools-4.6.1/squashfs-tools",
    urls = ["https://github.com/plougher/squashfs-tools/archive/refs/tags/4.6.1.tar.gz"],
)

# zlib compiled as a plain cc_library producing libz.a (for mksquashfs -lz).
http_archive(
    name = "zlib_src",
    build_file_content = """
cc_library(
    name = "z",
    srcs = glob([
        "*.c",
        "*.h",
    ]),
    hdrs = [
        "zconf.h",
        "zlib.h",
    ],
    includes = ["."],
    linkstatic = True,
    visibility = ["//visibility:public"],
)
""",
    sha256 = "9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23",
    strip_prefix = "zlib-1.3.1",
    urls = ["https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz"],
)

# zstd compiled as a plain cc_library producing libzstd.a (for mksquashfs
# -lzstd). Built single-threaded (no -DZSTD_MULTITHREAD) so the archive needs
# no pthread symbols, keeping the squashfs static link order valid. The x86_64
# assembly is dropped (-DZSTD_DISABLE_ASM) to keep the cc_library portable.
http_archive(
    name = "zstd_src",
    build_file_content = """
cc_library(
    name = "zstd",
    srcs = glob(
        [
            "lib/common/*.c",
            "lib/common/*.h",
            "lib/compress/*.c",
            "lib/compress/*.h",
            "lib/decompress/*.c",
            "lib/decompress/*.h",
        ],
    ),
    hdrs = [
        "lib/zstd.h",
        "lib/zstd_errors.h",
    ],
    copts = ["-DZSTD_DISABLE_ASM"],
    includes = ["lib"],
    linkstatic = True,
    visibility = ["//visibility:public"],
)
""",
    sha256 = "8c29e06cf42aacc1eafc4077ae2ec6c6fcb96a626157e0593d5e82a34fd403c1",
    strip_prefix = "zstd-1.5.6",
    urls = ["https://github.com/facebook/zstd/releases/download/v1.5.6/zstd-1.5.6.tar.gz"],
)

# popt 1.19 compiled as a plain cc_library producing libpopt.a. Required by
# sgdisk (gptfdisk) for command-line parsing. The upstream is autoconf-based,
# so a static config.h with the HAVE_* macros valid on glibc/bookworm is
# generated by genrule, matching what `./configure` would emit minus NLS
# (gettext/libintl are intentionally disabled — poptint.h already provides
# fallback `_()` / `D_()` / `POPT_()` / `N_()` macros when ENABLE_NLS is
# undefined). lookup3.c is textually #included by poptint.c, so it lives in
# textual_hdrs rather than srcs to avoid being compiled as a separate TU.
http_archive(
    name = "popt_src",
    build_file_content = """
genrule(
    name = "config_h",
    outs = ["config.h"],
    cmd = '''cat > $@ <<'EOF'
/* Bazel-generated config.h for popt 1.19 on glibc/bookworm. */
#define PACKAGE "popt"
#define PACKAGE_NAME "popt"
#define PACKAGE_VERSION "1.19"
#define PACKAGE_STRING "popt 1.19"
#define PACKAGE_TARNAME "popt"
#define PACKAGE_BUGREPORT ""
#define PACKAGE_URL ""
#define VERSION "1.19"
#define STDC_HEADERS 1
#define HAVE_STDIO_H 1
#define HAVE_STDLIB_H 1
#define HAVE_STRING_H 1
#define HAVE_STRINGS_H 1
#define HAVE_INTTYPES_H 1
#define HAVE_STDINT_H 1
#define HAVE_STDALIGN_H 1
#define HAVE_UNISTD_H 1
#define HAVE_SYS_STAT_H 1
#define HAVE_SYS_TYPES_H 1
#define HAVE_WCHAR_H 1
#define HAVE_LANGINFO_H 1
#define HAVE_FNMATCH_H 1
#define HAVE_GLOB_H 1
#define HAVE_DLFCN_H 1
#define HAVE_STPCPY 1
#define HAVE_STRERROR 1
#define HAVE_SECURE_GETENV 1
#define HAVE_VASPRINTF 1
#define HAVE_MBSRTOWCS 1
#define HAVE_GETEUID 1
#define HAVE_GETUID 1
#define HAVE_SETUID 1
#define HAVE_SETREUID 1
#define HAVE_SRANDOM 1
#define HAVE_GLOB_PATTERN_P 1
#define _GNU_SOURCE 1
EOF''',
)

cc_library(
    name = "popt",
    srcs = [
        "src/popt.c",
        "src/poptconfig.c",
        "src/popthelp.c",
        "src/poptint.c",
        "src/poptparse.c",
        "src/poptint.h",
        "src/system.h",
        ":config_h",
    ],
    hdrs = ["src/popt.h"],
    textual_hdrs = ["src/lookup3.c"],
    copts = [
        "-DHAVE_CONFIG_H",
        # POPT_SYSCONFDIR comes from autoconf's $sysconfdir; legacy SONiC
        # builds use /etc, matching the Debian libpopt0 package layout.
        '-DPOPT_SYSCONFDIR=\\\\"/etc\\\\"',
        "-Wno-implicit-function-declaration",
    ],
    includes = [
        ".",     # for the generated config.h
        "src",   # poptint.h / system.h
    ],
    strip_include_prefix = "src",
    linkstatic = True,
    visibility = ["//visibility:public"],
)
""",
    sha256 = "c25a4838fc8e4c1c8aacb8bd620edb3084a3d63bf8987fdad3ca2758c63240f9",
    strip_prefix = "popt-1.19",
    urls = ["http://ftp.rpm.org/popt/releases/popt-1.x/popt-1.19.tar.gz"],
)

# ----------------------------------------------------------------------------
# e2fsprogs 1.47.2 — mke2fs hermetic native Bazel build.
#
# Used by the sonic-vs.img.gz static assembly pipeline to create the ext4
# filesystem image. Compiled as a plain cc_binary plus per-subdir cc_library
# (libet/libuuid/libe2p/libblkid/libsupport/libext2fs), with the autoconf
# generated headers (lib/config.h, lib/ext2fs/ext2_types.h, ...) emitted via
# heredoc genrules in this build_file_content. The compile_et and
# profile-to-c.awk codegen are reproduced via awk genrules on the upstream
# .et / .conf inputs.
#
# The :uuid cc_library is exposed (visibility public) so other targets (e.g.
# the gptfdisk/sgdisk port at T4) can link the private libuuid without
# requiring the apt-installed libuuid1-dev.
# ----------------------------------------------------------------------------
http_archive(
    name = "e2fsprogs_src",
    build_file_content = """
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")

# -------- Generated headers (autoconf substitutes) ---------------------------

# lib/dirpaths.h: paths normally substituted from autoconf @datadir@ /
# @root_sysconfdir@. mke2fs only reads the conf file via -P/-T or the default
# /etc/mke2fs.conf, so /usr/share/locale and /etc match Debian layout.
genrule(
    name = "dirpaths_h",
    outs = ["lib/dirpaths.h"],
    cmd = '''cat > $@ <<'EOF'
#define LOCALEDIR    "/usr/share/locale"
#define ROOT_SYSCONFDIR "/etc"
EOF''',
)

# lib/config.h: the autoconf-generated HAVE_* / SIZEOF_* feature matrix. The
# values below are taken from `./configure --enable-libblkid --enable-libuuid
# --disable-nls --disable-fuse2fs --disable-uuidd --disable-tdb` against a
# Debian bookworm sysroot (glibc 2.36, Linux 6.1 headers) and trimmed to the
# macros actually consumed by the e2fsprogs sources. NLS / TDB / FUSE / blkid
# debug paths are intentionally left undefined.
genrule(
    name = "config_h",
    outs = ["lib/config.h"],
    cmd = '''cat > $@ <<'EOF'
/* Bazel-generated lib/config.h for e2fsprogs 1.47.2 on glibc/bookworm. */
#define CONFIG_BUILD_FINDFS 1
#define CONFIG_MMP 1
