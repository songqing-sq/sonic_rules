# ----------------------------------------------------------------------------
# kmod 34 — hermetic native Bazel host tool (depmod).
#
# `make modules_install` runs depmod to build modules.dep/.alias/.symbols/...
# The kernel config is CONFIG_MODULE_COMPRESS_NONE=y (uncompressed .ko) and
# CONFIG_MODULE_SIG_ALL is unset (no build-time signing), so depmod needs no
# compression (zlib/xz/zstd) and no crypto (openssl) — all disabled here.
#
# kmod is autotools; per the autoconf reference we do NOT run ./configure.
# config.h is generated by a heredoc genrule with the HAVE_*/ENABLE_* values
# valid for Debian bookworm glibc x86_64. Presence-style macros (tested with
# #ifndef / #ifdef / defined()) are defined to 1 only when the feature exists
# and OMITTED otherwise (HAVE_FINIT_MODULE is omitted so shared/missing.h
# supplies the syscall() wrapper — glibc here has no finit_module() symbol).
# Value-style macros (tested with #if VALUE: HAVE_DECL_BASENAME and the
# __builtin_*_overflow set) are always defined.
#
# kmod 34 ships a single multi-call `kmod` binary; depmod/insmod/modprobe/...
# are argv[0] dispatches. The exposed :depmod target is that binary renamed to
# `depmod`, so invoking it dispatches to the depmod applet.
#
# Source lists are taken verbatim from the upstream Makefile.am
# (shared_libshared_la_SOURCES, libkmod_libkmod_la_SOURCES base list with the
# compression files excluded, and tools_kmod_SOURCES).
# ----------------------------------------------------------------------------
http_archive(
    name = "kmod_src",
    build_file_content = """
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")

genrule(
    name = "config_h",
    outs = ["config.h"],
    cmd = '''cat > $@ <<'EOF'
/* Bazel-generated config.h for kmod 34 on glibc/bookworm x86_64. */
#ifndef KMOD_CONFIG_H
#define KMOD_CONFIG_H
#define PACKAGE "kmod"
#define VERSION "34"
#define ENABLE_ZSTD 0
#define ENABLE_ZSTD_DLOPEN 0
#define ENABLE_XZ 0
#define ENABLE_XZ_DLOPEN 0
#define ENABLE_ZLIB 0
#define ENABLE_ZLIB_DLOPEN 0
#define ENABLE_OPENSSL 0
#define ENABLE_LOGGING 1
#define ENABLE_DEBUG 0
#define ENABLE_ELFDBG 0
#define HAVE_SECURE_GETENV 1
#define HAVE_STATIC_ASSERT 1
#define HAVE_NORETURN 1
#define HAVE_STRUCT_STAT_ST_MTIM 1
#define HAVE_DECL_BASENAME 1
#define HAVE___BUILTIN_UADD_OVERFLOW 1
#define HAVE___BUILTIN_UADDL_OVERFLOW 1
#define HAVE___BUILTIN_UADDLL_OVERFLOW 1
#define HAVE___BUILTIN_UMUL_OVERFLOW 1
#define HAVE___BUILTIN_UMULL_OVERFLOW 1
#define HAVE___BUILTIN_UMULLL_OVERFLOW 1
#define KMOD_FEATURES ""
#endif
EOF''',
)

KMOD_COPTS = [
    "-include", "config.h",
    "-D_GNU_SOURCE",
    '-DSYSCONFDIR=\\\\"/etc\\\\"',
    '-DDISTCONFDIR=\\\\"/usr/lib\\\\"',
    '-DMODULE_DIRECTORY=\\\\"/lib/modules\\\\"',
    "-Wno-implicit-fallthrough",
]

# shared/libshared + libkmod (base list: no xz/zlib/zstd compression files,
# no openssl) compiled as a single internal cc_library.
cc_library(
    name = "kmod_internal",
    srcs = [
        # shared_libshared_la_SOURCES
        "shared/array.c",
        "shared/hash.c",
        "shared/strbuf.c",
        "shared/util.c",
        # libkmod_libkmod_la_SOURCES (base, ENABLE_* off)
        "libkmod/libkmod-builtin.c",
        "libkmod/libkmod.c",
        "libkmod/libkmod-config.c",
        "libkmod/libkmod-elf.c",
        "libkmod/libkmod-file.c",
        "libkmod/libkmod-index.c",
        "libkmod/libkmod-list.c",
        "libkmod/libkmod-module.c",
        "libkmod/libkmod-signature.c",
    ] + glob([
        "shared/*.h",
        "libkmod/*.h",
    ]) + [":config_h"],
    copts = KMOD_COPTS,
    includes = ["."],
    linkstatic = True,
)

# tools_kmod_SOURCES -> the multi-call kmod binary, exposed as `depmod`
# (argv[0] dispatch selects the depmod applet).
cc_binary(
    name = "depmod",
    srcs = [
        "tools/depmod.c",
        "tools/insmod.c",
        "tools/kmod.c",
        "tools/kmod.h",
        "tools/log.c",
        "tools/log.h",
        "tools/lsmod.c",
        "tools/modinfo.c",
        "tools/modprobe.c",
        "tools/opt.c",
        "tools/opt.h",
        "tools/rmmod.c",
        "tools/static-nodes.c",
        ":config_h",
    ],
    copts = KMOD_COPTS,
    includes = ["."],
    linkstatic = True,
    visibility = ["//visibility:public"],
    deps = [":kmod_internal"],
)
""",
    sha256 = "cb47be49366b596e4554eeeb7595b128feb261619c7675603e004b07c5ebbd5b",
    strip_prefix = "kmod-34",
    urls = ["https://github.com/kmod-project/kmod/archive/refs/tags/v34.tar.gz"],
)

# ----------------------------------------------------------------------------
# GNU cpio 2.14 — hermetic native Bazel host tool.
#
# Used by kbuild scripts for initramfs/cpio archive handling. cpio is autotools
# + a large gnulib portability layer. Per the autoconf reference we do NOT run
# ./configure or autoreconf, and we do NOT use rules_foreign_cc.
#
# gnulib generates ~24 override headers (stdio.h, unistd.h, fcntl.h, ...) plus
# config.h via sed recipes driven by hundreds of configure-computed
# substitution variables (GNULIB_*, REPLACE_*, HAVE_RAW_DECL_*, ...). Those
# values are fixed for Debian bookworm glibc x86_64. Rather than reproduce the
# sed recipes, the generated headers + config.h (the exact, deterministic
# configure output for that platform) are injected as new files via the
# http_archive `patches` mechanism (cpio/generated.patch). This is purely
# additive — no upstream source file is modified — so the result still compiles
# with plain cc_library/cc_binary.
#
# The cpio program links three native libraries built from source:
#   - libgnu  : the 89 gnulib .c objects that actually go into libgnu.a on
#               glibc (the conditional/no-op modules are simply not compiled),
#               taken verbatim from `ar t gnu/libgnu.a` of a reference build.
#   - libpax  : lib/libpax.a (paxutils helpers), from lib/Makefile.am
#               libpax_a_SOURCES.
#   - cpio    : src/*.c minus mt.c (the `mt` tape tool is a separate program),
#               i.e. cpio_SOURCES from src/Makefile.am.
# -fcommon restores the pre-GCC-10 common-symbol behavior the autotools
# archive link relies on (argp_program_bug_address is a tentative definition in
# multiple TUs). The warning suppressions mirror gnulib's GL_CFLAG_GNULIB_WARNINGS.
# ----------------------------------------------------------------------------
http_archive(
    name = "cpio_src",
    build_file_content = """
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")

CPIO_COPTS = [
    "-DHAVE_CONFIG_H",
    "-fcommon",
    "-Wno-cast-qual",
    "-Wno-conversion",
    "-Wno-float-equal",
    "-Wno-sign-compare",
    "-Wno-undef",
    "-Wno-unused-function",
    "-Wno-unused-parameter",
    "-Wno-float-conversion",
    "-Wimplicit-fallthrough",
    "-Wno-sign-conversion",
    "-Wno-type-limits",
    "-Wno-implicit-function-declaration",
]

CPIO_INCLUDES = [
    ".",     # config.h
    "gnu",   # gnulib generated + static headers
    "lib",   # paxutils headers
    "src",   # cpio internal headers
]

# safe-read.c is dual-purpose: compiled standalone it defines safe_read, and it
# is also textually #included by safe-write.c (which #defines SAFE_WRITE to
# produce safe_write). Since a file cannot be both a src and a textual_hdr, we
# stage safe-read.c as a textual header and synthesize a tiny standalone TU that
# #includes it to keep safe_read in libgnu.a.
genrule(
    name = "gnu_safe_read_tu",
    outs = ["gnu/safe_read_standalone.c"],
    cmd = "echo '#include \\"safe-read.c\\"' > $@",
)

# gnulib portability layer. Source list = the objects that actually land in
# libgnu.a on glibc/bookworm (89 files).
cc_library(
    name = "gnu",
    srcs = [
        "gnu/argmatch.c",
