# Keep bazel_compatibility in sync with sonic-buildimage's .bazelversion.
module(
    name = "sonic-build-infra",
    version = "0.0.0",
    bazel_compatibility = [
        ">=8.5.1",
        "<=8.6.0",
    ],
)

bazel_dep(name = "swig", version = "4.1.0")
bazel_dep(name = "protobuf", version = "29.0")
bazel_dep(name = "rules_cc", version = "0.2.14")
bazel_dep(name = "rules_python", version = "1.7.0")
bazel_dep(name = "aspect_rules_py", version = "1.8.4")
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "tar.bzl", version = "0.8.1")
# @gawk: the sealed awk that //initramfs:defs.bzl and //tar:assert_tar.bzl take.
# gawk is already in the module graph (pulled transitively by rules_distroless
# and tar.bzl); this bazel_dep makes @gawk resolve to that module within this
# module's repo namespace, so the bare @gawk label in those rules works (root-
# module repos are not visible here). @gawk//:gawk is a prebuilt cc_binary.
bazel_dep(name = "gawk", version = "5.3.2.bcr.3")

# TODO(bazel-ready): Upgrade tar.bzl when the version with this commit releases.
git_override(
    module_name = "tar.bzl",
    commit = "9b76e660363ab2465d89d3aadbbc1f7afa02e65c",
    remote = "https://github.com/bazel-contrib/tar.bzl",
)

bazel_dep(name = "bazel_skylib", version = "1.8.2")
bazel_dep(name = "bazel_lib", version = "3.1.1")

# Host-tool toolchains used by //kernel:host_tools.bzl (flex/bison/m4/perl).
# The @flex/@bison/@m4/@perl repos + toolchain registration are provided by the
# consuming root module; these deps make the @rules_*//...:toolchain_type labels
# resolvable from within @sonic_build_infra.
bazel_dep(name = "rules_flex", version = "0.4")
bazel_dep(name = "rules_bison", version = "0.4")
bazel_dep(name = "rules_m4", version = "0.3")
bazel_dep(name = "rules_perl", version = "1.1.0")

bazel_dep(name = "rules_distroless", version = "0.0.0")
git_override(
    module_name = "rules_distroless",
    commit = "815b4b3",
    remote = "https://github.com/songqing-sq/rules_distroless.git",
)

fetch_gcc = use_repo_rule("//toolchains/gcc:gcc.bzl", "fetch_gcc")

fetch_gcc(
    name = "gcc-linux-x86_64",
    integrity = "sha256-UQduF1g5tDS7LcAAbACWkW31hejERmbTWw486CHVNds=",
    urls = ["https://github.com/f0rmiga/gcc-builds/releases/download/18082025/gcc-toolchain-12.5.0-x86_64.tar.xz"],
)

# fetch_gcc(
#     name = "gcc-linux-x86_64",
#     integrity = "sha256-CzZeXaRR9cetxZT5Z4hdcYH/bRh9YImkvPNvlUvzzPk=",
#     urls = ["https://github.com/f0rmiga/gcc-builds/releases/download/18082025/gcc-toolchain-14.3.0-x86_64.tar.xz"],
# )

fetch_gcc(
    name = "gcc-linux-aarch64",
    integrity = "sha256-ew4lEzqY1EtkipJboR9ko63EcOh2aK+Aziw684nr6b4=",
    urls = ["https://github.com/f0rmiga/gcc-builds/releases/download/18082025/gcc-toolchain-12.5.0-aarch64.tar.xz"],
    prefix = "aarch64-linux",
)

register_toolchains(
    "//toolchains/gcc:linux_x86_64",
    "//toolchains/gcc:cross_aarch64",
)

apt = use_extension("@rules_distroless//apt:extensions.bzl", "apt")

# NOTE: sources are keyed by suite in rules_distroless, so the same suite must
# declare every architecture in one sources_list. Splitting amd64/arm64 into
# separate tags would let the later one overwrite the former, and since
# apt.install derives target architectures from the suite's sources, the
# dependency set would collapse onto a single (the last-declared) architecture.
apt.sources_list(
    architectures = ["amd64", "arm64"],
    components = ["main"],
    suites = ["bookworm", "bookworm-updates"],
    uris = ["https://snapshot.debian.org/archive/debian/20260409T202916Z"],
)
apt.sources_list(
    architectures = ["amd64", "arm64"],
    components = ["main"],
    suites = ["bookworm-security"],
    uris = ["https://snapshot.debian.org/archive/debian-security/20260409T182303Z"],
)

# Single multi-arch sysroot. The generated @sysroot-bookworm//:directory
# select()s the right packages from the target platform's CPU constraint, so
# one set serves both the x86_64 and aarch64 cc toolchains.
apt.install(
    dependency_set = "sysroot-bookworm",
    packages = ["libc6-dev", "libstdc++6", "linux-libc-dev"],
    suites = ["bookworm", "bookworm-updates", "bookworm-security"],
)

use_repo(apt, "sysroot-bookworm")

# pip hub for build-time Python tools (e.g. the jinja2 renderer). Declared in
# this module so targets under @sonic_build_infra can depend on @pip_tools//...
# without relying on the root module's separate "pip" hub, which is not visible
# here. Uses the same aspect_rules_py uv extension as docker-base-bookworm.
uv = use_extension("@aspect_rules_py//uv/unstable:extension.bzl", "uv")
uv.declare_hub(hub_name = "pip_tools")
uv.declare_venv(
    hub_name = "pip_tools",
    venv_name = "default",
)
uv.lockfile(
    src = "//jinja2:uv.lock",
    hub_name = "pip_tools",
    venv_name = "default",
)

# Build-time pyang (YANG codegen) runner. Separate venv on the same pip_tools
# hub so @sonic_build_infra//pyang:pyang can depend on @pip_tools//pyang.
uv.declare_venv(
    hub_name = "pip_tools",
    venv_name = "pyang",
)
uv.lockfile(
    src = "//pyang:uv.lock",
    hub_name = "pip_tools",
    venv_name = "pyang",
)
use_repo(uv, "pip_tools")

# rules_pkg removed: sonic_deb now uses ar/tar/objcopy directly from CC toolchain
# TODO(bazel-ready): Add auto-formatting with buildifier
# ----------------------------------------------------------------------------
# GNU tar 1.35 — hermetic native Bazel build (replaces the host `tar`).
#
# Three rootfs-assembly steps need GNU tar specifically (NOT the sealed bsdtar
# from @tar.bzl): squashfs/rootfs extraction relies on `--keep-directory-symlink`
# (debootstrap-style merged-/usr) and on `-p` preserving setuid on the build
# user's own files (sudo/mount/su); onie_mk packs the installer/ dir with `-h`.
# bsdtar drops setuid on non-root extraction and lacks --keep-directory-symlink,
# so a from-source GNU tar is required.
#
# tar's lib/ is gnulib (portability shims). gnulib's headers (stdio.h, fcntl.h,
# getopt.h, configmake.h, ...) and config.h are *generated* by ./configure from
# @GNULIB_*@-substituted .in.h templates -- 41 headers + config.h, far too large
# and sed-heavy to hand-write as heredocs. They are instead captured once (by
# running ./configure against the same gcc-12.5.0 + @sysroot-bookworm toolchain
# this build uses) and committed under //tar/gen. The 178 gnulib .c sources, 6
# paxutils lib/ .c, and 24 tar src/ .c are compiled straight from this archive
# against those committed generated headers (see //tar:BUILD.bazel). The 178
# gnulib sources are listed explicitly: gnu/ ships 278 .c (alternate impls), of
# which configure selects only 156 + 22 across malloc/unicase/unictype/uniwidth.
#
# acl/selinux are disabled (the bookworm sysroot carries no libacl/libselinux),
# so the acl-*/se-* sources compile as no-op stubs and tar links libc only.
# ----------------------------------------------------------------------------
http_archive(
    name = "tar_src",
    build_file_content = """
load("@rules_cc//cc:cc_library.bzl", "cc_library")

# All upstream files are exported so //tar:tar_bin (in the main module) can pick
# the exact .c subset configure selects; the generated headers + config.h come
# from //tar:gen, kept out of this read-only archive.
exports_files(glob(["**"]))

# Header-only lib carrying the upstream include roots. `includes` must live on a
# target *inside this repo* so the emitted -I paths resolve to
# external/tar_src+/{gnu,lib,src} (the Makefile's -Ignu -Ilib + src self-include);
# declaring them on a main-module cc_library would make -I main-package-relative
# and miss the @tar_src headers. config.h and the generated gnulib headers are
# supplied separately by //tar:gen_headers.
cc_library(
    name = "headers",
    hdrs = glob(["gnu/**/*.h", "lib/*.h", "src/*.h"]),
    # Several gnulib sources textually `#include "other.c"` (e.g. full-read.c
    # includes full-write.c under -DFULL_READ to instantiate the read variant;
    # strtol.c/inttostr.c/... do the same). Those .c are also compiled standalone
    # (different macro -> different symbol, no duplicate). Exposing every .c as a
    # textual_hdr puts them on the include path for the quote-include to resolve,
    # without compiling them in this lib.
    textual_hdrs = glob(["gnu/**/*.c", "lib/*.c", "src/*.c"]),
    includes = ["gnu", "lib", "src"],
    visibility = ["//visibility:public"],
)
""",
    sha256 = "14d55e32063ea9526e057fbf35fcabd53378e769787eff7919c3755b02d2b57e",
    strip_prefix = "tar-1.35",
    urls = ["https://ftp.gnu.org/gnu/tar/tar-1.35.tar.gz"],
)

# ----------------------------------------------------------------------------
# elfutils 0.190 — libelf + libdw hermetic native Bazel host libraries.
#
# Needed by pahole (@dwarves_src//:pahole), the BTF generator the kernel build
# invokes when CONFIG_DEBUG_INFO_BTF=y. pahole links -ldw -lelf, and libdw
# pulls in libdwfl/libebl/libdwelf/libcpu plus the per-architecture ELF
# backends (backends/*.c), all statically linked (elfutils 0.190 dispatches
# backends through the in-tree machines[] table, not dlopen).
#
# elfutils is autotools; per the autoconf reference we do NOT run ./configure.
# config.h is hand-written below via genrule with the HAVE_* matrix valid for
# Debian bookworm glibc x86_64 (and aarch64 — header/function availability is
# glibc-version, not arch, dependent). SYMBOL_VERSIONING is intentionally left
# undefined so the .symver machinery in lib/eu-config.h collapses to plain C
# names (correct for static linking into one executable). USE_LOCKS is off
# (configure default --disable-thread-safety). Only zlib decompression is
# enabled (USE_ZLIB); bzip2/lzma/zstd backends are dropped (their .c files are
# autoconf-conditional and unused for reading the kernel's zlib/uncompressed
# DWARF). debuginfod is disabled — debuginfod-client.c compiles to a NULL stub
# when ENABLE_LIBDEBUGINFOD is undefined.
#
# Generated inputs: all release-shipped generated headers (libdw/known-dwarf.h,
# libcpu/{i386,x86_64}_dis.h, libcpu/i386_mne.h) are used as-is. Only the
# disassembler mnemonic tables are not shipped; they are reproduced with the
# exact upstream m4 + sed|sort pipeline (libcpu/Makefile.am rules) via genrule.
# ----------------------------------------------------------------------------
http_archive(
    name = "elfutils_src",
    build_file_content = """
load("@rules_cc//cc:cc_library.bzl", "cc_library")

# -------- config.h (autoconf substitute) -------------------------------------
# Hand-written HAVE_* matrix for Debian bookworm glibc. config.h.in ends with
# `#include <eu-config.h>`, reproduced here. SYMBOL_VERSIONING / USE_LOCKS /
# ENABLE_LIBDEBUGINFOD / USE_BZLIB / USE_LZMA / USE_ZSTD are deliberately
# left undefined.
genrule(
    name = "config_h",
    outs = ["config.h"],
    cmd = '''cat > $@ <<'EOF'
/* Bazel-generated config.h for elfutils 0.190 on glibc/bookworm. */
#define PACKAGE "elfutils"
#define PACKAGE_NAME "elfutils"
#define PACKAGE_STRING "elfutils 0.190"
#define PACKAGE_TARNAME "elfutils"
#define PACKAGE_URL "http://elfutils.org/"
#define PACKAGE_VERSION "0.190"
#define PACKAGE_BUGREPORT "https://sourceware.org/bugzilla"
#define VERSION "0.190"
#define STDC_HEADERS 1
#define HAVE_INTTYPES_H 1
#define HAVE_STDINT_H 1
#define HAVE_STDIO_H 1
#define HAVE_STDLIB_H 1
#define HAVE_STRING_H 1
#define HAVE_STRINGS_H 1
#define HAVE_SYS_STAT_H 1
#define HAVE_SYS_TYPES_H 1
#define HAVE_UNISTD_H 1
#define HAVE_ERROR_H 1
#define HAVE_ERR_H 1
#define HAVE_EXECINFO_H 1
#define HAVE_SCHED_H 1
#define HAVE_SYS_RESOURCE_H 1
#define HAVE_STDATOMIC_H 1
#define HAVE_DECL_MEMRCHR 1
#define HAVE_DECL_MEMPCPY 1
#define HAVE_DECL_RAWMEMCHR 1
#define HAVE_DECL_REALLOCARRAY 1
#define HAVE_DECL_STRERROR_R 1
#define HAVE_DECL_POWEROF2 1
#define HAVE_GETRLIMIT 1
#define HAVE_MREMAP 1
#define HAVE_PROCESS_VM_READV 1
#define HAVE_SCHED_GETAFFINITY 1
#define HAVE_SYS_USER_REGS 1
#define HAVE_FALLTHROUGH 1
#define HAVE_VISIBILITY 1
#define HAVE_GCC_STRUCT 1
#define HAVE_STRERROR_R 1
#define SIZEOF_LONG 8
#define USE_ZLIB 1
#define _GNU_SOURCE 1
#include <eu-config.h>
EOF''',
)

# -------- disassembler mnemonic tables (m4 + sed|sort codegen) ----------------
# libcpu/Makefile.am: `%_defs: defs/i386` -> `m4 -D<arch> -DDISASSEMBLER` and
# `%.mnemonics: %_defs` -> the sed | sort -u pipeline. The *_dis.h tables that
# reference these MNE() macros are shipped pre-generated in the tarball.
genrule(
    name = "i386_defs",
    srcs = ["libcpu/defs/i386"],
    outs = ["libcpu/i386_defs"],
    cmd = "m4 -Di386 -DDISASSEMBLER $< > $@",
)

genrule(
    name = "x86_64_defs",
    srcs = ["libcpu/defs/i386"],
    outs = ["libcpu/x86_64_defs"],
    cmd = "m4 -Dx86_64 -DDISASSEMBLER $< > $@",
)

genrule(
    name = "i386_mnemonics",
    srcs = [":i386_defs"],
    outs = ["libcpu/i386.mnemonics"],
    cmd = "sed '1,/^%%/d;/^#/d;/^[[:space:]]*$$/d;s/[^:]*:\\\\([^[:space:]]*\\\\).*/MNE(\\\\1)/;s/{[^}]*}//g;/INVALID/d' $< | sort -u > $@",
)

genrule(
    name = "x86_64_mnemonics",
    srcs = [":x86_64_defs"],
    outs = ["libcpu/x86_64.mnemonics"],
    cmd = "sed '1,/^%%/d;/^#/d;/^[[:space:]]*$$/d;s/[^:]*:\\\\([^[:space:]]*\\\\).*/MNE(\\\\1)/;s/{[^}]*}//g;/INVALID/d' $< | sort -u > $@",
)

# -------- internal headers visible to every elfutils TU ----------------------
# Reproduces the base AM_CPPFLAGS (-I. -Ilib -I<own dir> -I sibling libs).
# config.h lives at the repo root; lib/ supplies eu-config.h / system.h; the
# per-lib dirs supply the *P.h private headers and the public headers that the
# .c files include flat (<libdw.h>, <gelf.h>, <dwarf.h>, <libasm.h> ...).
cc_library(
    name = "internal_hdrs",
    hdrs = glob([
        "lib/*.h",
        "libelf/*.h",
        "libdw/*.h",
        "libdwfl/*.h",
        "libdwelf/*.h",
        "libebl/*.h",
        "libcpu/*.h",
        "libasm/*.h",
        "backends/*.h",
    ]) + [":config_h"],
    # lib/dynamicsizehash{,_concurrent}.c are hash-table templates textually
    # #included (e.g. libdw/dwarf_abbrev_hash.c does
    # #include <dynamicsizehash_concurrent.c>), never compiled standalone.
    textual_hdrs = [
        "lib/dynamicsizehash.c",
        "lib/dynamicsizehash_concurrent.c",
    ],
    includes = [
        ".",
        "lib",
        "libelf",
        "libdw",
        "libdwfl",
        "libdwelf",
        "libebl",
        "libcpu",
        "libasm",
        "backends",
    ],
    visibility = ["//visibility:private"],
)

EU_COPTS = [
    "-DHAVE_CONFIG_H",
    "-D_GNU_SOURCE",
    "-D_FILE_OFFSET_BITS=64",
    "-D_LARGEFILE64_SOURCE",
    "-std=gnu99",
    "-Wno-error",
    "-Wno-unused-parameter",
    "-Wno-unused-result",
    "-Wno-sign-compare",
    "-Wno-implicit-fallthrough",
    "-Wno-deprecated-declarations",
    "-Wno-pointer-arith",
]

# -------- libelf -------------------------------------------------------------
# elf64_*.c textually #include the sibling elf32_*.c (the LIBELFBITS pattern:
# the same .c yields the 32-bit instantiation when compiled standalone and the
# 64-bit one when #included with LIBELFBITS=64). Bazel stages only the TU being
# compiled plus declared headers, so the elf32_*.c are listed as textual_hdrs
# (for the 64-bit #include) and compiled standalone via the :elf32 target.
ELF32_BITS_SRCS = [
    "libelf/elf32_checksum.c",
    "libelf/elf32_fsize.c",
    "libelf/elf32_getchdr.c",
    "libelf/elf32_getehdr.c",
    "libelf/elf32_getphdr.c",
    "libelf/elf32_getshdr.c",
    "libelf/elf32_newehdr.c",
    "libelf/elf32_newphdr.c",
    "libelf/elf32_offscn.c",
    "libelf/elf32_updatefile.c",
    "libelf/elf32_updatenull.c",
    "libelf/elf32_xlatetof.c",
    "libelf/elf32_xlatetom.c",
]

cc_library(
    name = "elf32",
    srcs = ELF32_BITS_SRCS,
    copts = EU_COPTS,
    linkstatic = True,
    visibility = ["//visibility:private"],
    deps = [":internal_hdrs", "@zlib_src//:z"],
)

cc_library(
    name = "elf",
    srcs = glob(["libelf/*.c"], exclude = ELF32_BITS_SRCS),
    copts = EU_COPTS,
    linkstatic = True,
    # libelf_next_prime.c / libelf_crc32.c textually #include "../lib/*.c".
    textual_hdrs = ELF32_BITS_SRCS + [
        "lib/next_prime.c",
        "lib/crc32.c",
    ],
    visibility = ["//visibility:public"],
    deps = [":internal_hdrs", ":elf32", "@zlib_src//:z"],
)

# -------- dual-role / textual-only backend & libcpu sources ------------------
# eblopenbackend.c's machines[] table names every <arch>_init, so all backends
# must link or the static link fails on undefined symbols (they are compiled
# into :dw below).
#
# Textual-only backend .c (noinst_HEADERS): common-reloc.c, linux-core-note.c,
# x86_corenote.c — #included, never compiled standalone.
#
# Dual-role backend .c: the base-width *_corenote.c are compiled standalone AND
# #included by their wider sibling (e.g. ppc64_corenote.c #includes
# ppc_corenote.c). They are compiled in :ebl_corenote and exposed as
# textual_hdrs of :dw for the sibling #include. None of them reference libdw
# symbols, so :ebl_corenote does not create a libdw<->libebl cycle.
EBL_CORENOTE_DUAL = [
    "backends/ppc_corenote.c",
    "backends/riscv_corenote.c",
    "backends/s390_corenote.c",
    "backends/sparc_corenote.c",
    "backends/x86_64_corenote.c",
]

# common-reloc.c does `#include RELOC_TYPES` -> "<arch>_reloc.def"; the 17
# *_reloc.def files are EXTRA_DIST (shipped), textually #included per backend
# and added to textual_hdrs below.
EBL_TEXTUAL_ONLY = [
    "backends/common-reloc.c",
    "backends/linux-core-note.c",
    "backends/x86_corenote.c",
]

EBL_TEXTUAL_HDRS = EBL_TEXTUAL_ONLY + EBL_CORENOTE_DUAL + glob(["backends/*_reloc.def"])

# i386_disasm.c is compiled standalone here (32-bit disassembler) and is also
# textually #included by x86_64_disasm.c (compiled in :dw). It pulls the
# mnemonic tables via i386_mne.h. The disassembler has no libdw references.
cc_library(
    name = "cpu",
    srcs = ["libcpu/i386_disasm.c"],
    copts = EU_COPTS,
    linkstatic = True,
    textual_hdrs = [
        ":i386_mnemonics",
        ":x86_64_mnemonics",
    ],
    deps = [":internal_hdrs"],
)

cc_library(
    name = "ebl_corenote",
    srcs = EBL_CORENOTE_DUAL,
    copts = EU_COPTS,
    linkstatic = True,
    textual_hdrs = EBL_TEXTUAL_HDRS,
    visibility = ["//visibility:private"],
    deps = [":internal_hdrs"],
)

# -------- libdw + libdwfl + libdwelf + libebl + backends + libcpu ------------
# libdw and libebl/backends are mutually dependent (backend retval/cfi code
# calls dwarf_peel_type / dwarf_aggregate_size, while libdw dispatches through
# the EBL backends). Upstream resolves this by linking libebl + the backends
# into libdw.so with --whole-archive. With static cc_library archives a
# two-target cycle cannot be resolved in a single link pass, so libebl, the
# backends, libcpu and libeu are compiled into this one :dw archive — matching
# the upstream libdw.so composition.
#
# bzip2.c / lzma.c / zstd.c are autoconf-conditional (BZLIB/LZMA/ZSTD) and
# omitted; gzip.c provides the zlib path consumed for SHF_COMPRESSED debug
# sections.
cc_library(
    name = "dw",
    srcs = glob(["libdw/*.c", "libdwelf/*.c", "libebl/*.c"]) + glob(
        ["libdwfl/*.c"],
        exclude = [
            "libdwfl/bzip2.c",
            "libdwfl/lzma.c",
            "libdwfl/zstd.c",
        ],
    ) + glob(
        ["backends/*.c"],
        # The dual-role *_corenote.c (EBL_CORENOTE_DUAL) are compiled in
        # :ebl_corenote and also #included by their wider sibling, so they are
        # textual_hdrs here, not srcs.
        exclude = EBL_TEXTUAL_ONLY + EBL_CORENOTE_DUAL,
    ) + [
        # libcpu disasm: i386_disasm.c is compiled in :cpu (and #included by
        # x86_64_disasm.c), so only the other three are compiled here.
        "libcpu/x86_64_disasm.c",
        "libcpu/bpf_disasm.c",
        "libcpu/riscv_disasm.c",
        "lib/xasprintf.c",
        "lib/xstrdup.c",
        "lib/xstrndup.c",
        "lib/xmalloc.c",
        "lib/next_prime.c",
        "lib/crc32.c",
        "lib/crc32_file.c",
        "lib/color.c",
        "lib/error.c",
        "lib/printversion.c",
    ],
    copts = EU_COPTS,
    linkopts = ["-lpthread"],
    linkstatic = True,
    # Cross-directory / per-arch textual .c includes: libdwfl_crc32{,_file}.c
    # pull ../lib/crc32{,_file}.c; x86_64_disasm.c pulls i386_disasm.c + the
    # mnemonics; the backends pull common-reloc.c / *_reloc.def / the dual
    # *_corenote.c / x86_corenote.c.
    textual_hdrs = [
        "lib/crc32.c",
        "lib/crc32_file.c",
        "libcpu/i386_disasm.c",
        ":i386_mnemonics",
        ":x86_64_mnemonics",
    ] + EBL_TEXTUAL_HDRS,
    visibility = ["//visibility:public"],
    deps = [":internal_hdrs", ":elf", ":cpu", ":ebl_corenote", "@zlib_src//:z"],
)

# -------- public headers for downstream consumers (dwarves) ------------------
# dwarves includes <elfutils/libdwfl.h>, <elfutils/version.h>, <dwarf.h> and
# (flat) <gelf.h>/<libelf.h>. The elfutils/-prefixed set is exposed via a
# generated copy under an elfutils/ subdir; the flat headers come from the
# libdw/libelf include dirs.
genrule(
    name = "elfutils_pub_hdrs",
    srcs = [
        "libdwfl/libdwfl.h",
        "version.h",
        "libdw/libdw.h",
    ],
    outs = [
        "pub/elfutils/libdwfl.h",
        "pub/elfutils/version.h",
        "pub/elfutils/libdw.h",
    ],
    cmd = "mkdir -p $(RULEDIR)/pub/elfutils && " +
