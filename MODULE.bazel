# ----------------------------------------------------------------------------
# bc 7.0.3 (gavinhoward) — hermetic native Bazel host tool.
#
# Kbuild uses `bc` for integer arithmetic in a handful of scripts (e.g.
# kernel/time/timeconst.bc). bc is NOT autotools; its custom configure.sh
# normally generates a Makefile and embeds the bc math libraries (gen/*.bc)
# and help text (gen/*.txt) into C source via the gen/strgen.c codegen tool.
# That codegen is reproduced here: strgen is built as a tiny host cc_binary
# and run via genrules with the EXACT argument vectors from the upstream
# Makefile.in (strgen <input> <output> <exclude> <name> [label [define
# [remove_tabs]]]). The resulting lib.c/lib2.c/bc_help.c/dc_help.c are linked
# as ordinary objects (they define the bc_lib/bc_lib2/bc_help/dc_help symbols
# that src/data.c declares extern).
#
# Config is a minimal `bc` build: history and NLS disabled (no readline /
# editline / libintl), extra math enabled (lib2.bc). The -D set and the
# numeric DEFAULT_* values are exactly those configure.sh emits for the
# default build type, with BC_ENABLE_HISTORY=0 and BC_ENABLE_NLS=0.
# ----------------------------------------------------------------------------
http_archive(
    name = "bc_src",
    build_file_content = """
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")

# Compile-time -D macro set shared by strgen and bc. Mirrors the resolved
# CFLAGS from the upstream-generated Makefile, minus history/NLS.
BC_COPTS = [
    "-DBC_ENABLED=1",
    "-DDC_ENABLED=1",
    "-DBUILD_TYPE=A",
    "-DBC_NUM_KARATSUBA_LEN=32",
    "-DBC_ENABLE_NLS=0",
    "-DBC_ENABLE_EXTRA_MATH=1",
    "-DBC_ENABLE_HISTORY=0",
    "-DBC_ENABLE_LIBRARY=0",
    "-DBC_ENABLE_MEMCHECK=0",
    "-DBC_ENABLE_AFL=0",
    "-DBC_ENABLE_OSSFUZZ=0",
    "-DBC_DEFAULT_BANNER=0",
    "-DBC_DEFAULT_SIGINT_RESET=1",
    "-DBC_DEFAULT_TTY_MODE=1",
    "-DBC_DEFAULT_PROMPT=1",
    "-DBC_DEFAULT_EXPR_EXIT=1",
    "-DBC_DEFAULT_DIGIT_CLAMP=0",
    "-DDC_DEFAULT_SIGINT_RESET=1",
    "-DDC_DEFAULT_TTY_MODE=0",
    "-DDC_DEFAULT_PROMPT=0",
    "-DDC_DEFAULT_EXPR_EXIT=1",
    "-DDC_DEFAULT_DIGIT_CLAMP=0",
    "-DNDEBUG",
    "-DBC_ENABLE_EDITLINE=0",
    "-DBC_ENABLE_READLINE=0",
    "-D_POSIX_C_SOURCE=200809L",
    "-D_XOPEN_SOURCE=700",
]

# strgen: the gen/ codegen host tool that embeds .bc / .txt files as C arrays.
cc_binary(
    name = "strgen",
    srcs = ["gen/strgen.c"],
    copts = BC_COPTS,
    includes = ["include"],
    # status.h (pulled in by strgen.c) lives in include/.
    deps = [":bc_headers"],
)

cc_library(
    name = "bc_headers",
    hdrs = glob(["include/*.h"]),
    includes = ["include"],
)

# Generated C sources. Argument vectors are taken verbatim from the upstream
# Makefile.in strgen recipes (exclude=0 -> keep extra-math sections).
genrule(
    name = "gen_lib_c",
    srcs = ["gen/lib.bc"],
    outs = ["lib.c"],
    tools = [":strgen"],
    cmd = "$(location :strgen) $(location gen/lib.bc) $@ 0 bc_lib bc_lib_name BC_ENABLED 1",
)

genrule(
    name = "gen_lib2_c",
    srcs = ["gen/lib2.bc"],
    outs = ["lib2.c"],
    tools = [":strgen"],
