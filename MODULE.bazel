# -------- disassembler mnemonic tables (m4 + sed|sort codegen) ----------------
# libcpu/Makefile.am: `%_defs: defs/i386` -> `m4 -D<arch> -DDISASSEMBLER` and
# `%.mnemonics: %_defs` -> the sed | sort -u pipeline. The *_dis.h tables that
# reference these MNE() macros are shipped pre-generated in the tarball.
genrule(
    name = "i386_defs",
    srcs = ["libcpu/defs/i386"],
    outs = ["libcpu/i386_defs"],
    cmd = "m4 -Di386 -DDISASSEMBLER $< > $@",
)

genrule(
    name = "x86_64_defs",
    srcs = ["libcpu/defs/i386"],
    outs = ["libcpu/x86_64_defs"],
    cmd = "m4 -Dx86_64 -DDISASSEMBLER $< > $@",
)

genrule(
    name = "i386_mnemonics",
    srcs = [":i386_defs"],
    outs = ["libcpu/i386.mnemonics"],
    cmd = "sed '1,/^%%/d;/^#/d;/^[[:space:]]*$$/d;s/[^:]*:\\\\([^[:space:]]*\\\\).*/MNE(\\\\1)/;s/{[^}]*}//g;/INVALID/d' $< | sort -u > $@",
)

genrule(
    name = "x86_64_mnemonics",
    srcs = [":x86_64_defs"],
    outs = ["libcpu/x86_64.mnemonics"],
    cmd = "sed '1,/^%%/d;/^#/d;/^[[:space:]]*$$/d;s/[^:]*:\\\\([^[:space:]]*\\\\).*/MNE(\\\\1)/;s/{[^}]*}//g;/INVALID/d' $< | sort -u > $@",
)

# -------- internal headers visible to every elfutils TU ----------------------
# Reproduces the base AM_CPPFLAGS (-I. -Ilib -I<own dir> -I sibling libs).
# config.h lives at the repo root; lib/ supplies eu-config.h / system.h; the
# per-lib dirs supply the *P.h private headers and the public headers that the
# .c files include flat (<libdw.h>, <gelf.h>, <dwarf.h>, <libasm.h> ...).
cc_library(
    name = "internal_hdrs",
    hdrs = glob([
        "lib/*.h",
        "libelf/*.h",
        "libdw/*.h",
        "libdwfl/*.h",
        "libdwelf/*.h",
        "libebl/*.h",
        "libcpu/*.h",
        "libasm/*.h",
        "backends/*.h",
    ]) + [":config_h"],
    # lib/dynamicsizehash{,_concurrent}.c are hash-table templates textually
    # #included (e.g. libdw/dwarf_abbrev_hash.c does
    # #include <dynamicsizehash_concurrent.c>), never compiled standalone.
    textual_hdrs = [
        "lib/dynamicsizehash.c",
        "lib/dynamicsizehash_concurrent.c",
    ],
    includes = [
        ".",
        "lib",
        "libelf",
        "libdw",
        "libdwfl",
        "libdwelf",
        "libebl",
        "libcpu",
        "libasm",
        "backends",
    ],
    visibility = ["//visibility:private"],
)

EU_COPTS = [
    "-DHAVE_CONFIG_H",
    "-D_GNU_SOURCE",
    "-D_FILE_OFFSET_BITS=64",
    "-D_LARGEFILE64_SOURCE",
    "-std=gnu99",
    "-Wno-error",
    "-Wno-unused-parameter",
    "-Wno-unused-result",
    "-Wno-sign-compare",
    "-Wno-implicit-fallthrough",
    "-Wno-deprecated-declarations",
    "-Wno-pointer-arith",
]

# -------- libelf -------------------------------------------------------------
# elf64_*.c textually #include the sibling elf32_*.c (the LIBELFBITS pattern:
# the same .c yields the 32-bit instantiation when compiled standalone and the
# 64-bit one when #included with LIBELFBITS=64). Bazel stages only the TU being
# compiled plus declared headers, so the elf32_*.c are listed as textual_hdrs
# (for the 64-bit #include) and compiled standalone via the :elf32 target.
ELF32_BITS_SRCS = [
    "libelf/elf32_checksum.c",
    "libelf/elf32_fsize.c",
    "libelf/elf32_getchdr.c",
    "libelf/elf32_getehdr.c",
    "libelf/elf32_getphdr.c",
    "libelf/elf32_getshdr.c",
    "libelf/elf32_newehdr.c",
    "libelf/elf32_newphdr.c",
    "libelf/elf32_offscn.c",
    "libelf/elf32_updatefile.c",
    "libelf/elf32_updatenull.c",
    "libelf/elf32_xlatetof.c",
    "libelf/elf32_xlatetom.c",
]

cc_library(
    name = "elf32",
    srcs = ELF32_BITS_SRCS,
    copts = EU_COPTS,
    linkstatic = True,
    visibility = ["//visibility:private"],
    deps = [":internal_hdrs", "@zlib_src//:z"],
)

cc_library(
    name = "elf",
    srcs = glob(["libelf/*.c"], exclude = ELF32_BITS_SRCS),
    copts = EU_COPTS,
    linkstatic = True,
    # libelf_next_prime.c / libelf_crc32.c textually #include "../lib/*.c".
    textual_hdrs = ELF32_BITS_SRCS + [
        "lib/next_prime.c",
        "lib/crc32.c",
    ],
    visibility = ["//visibility:public"],
    deps = [":internal_hdrs", ":elf32", "@zlib_src//:z"],
)

# -------- dual-role / textual-only backend & libcpu sources ------------------
# eblopenbackend.c's machines[] table names every <arch>_init, so all backends
# must link or the static link fails on undefined symbols (they are compiled
# into :dw below).
#
# Textual-only backend .c (noinst_HEADERS): common-reloc.c, linux-core-note.c,
# x86_corenote.c — #included, never compiled standalone.
#
# Dual-role backend .c: the base-width *_corenote.c are compiled standalone AND
# #included by their wider sibling (e.g. ppc64_corenote.c #includes
# ppc_corenote.c). They are compiled in :ebl_corenote and exposed as
# textual_hdrs of :dw for the sibling #include. None of them reference libdw
# symbols, so :ebl_corenote does not create a libdw<->libebl cycle.
EBL_CORENOTE_DUAL = [
    "backends/ppc_corenote.c",
    "backends/riscv_corenote.c",
    "backends/s390_corenote.c",
    "backends/sparc_corenote.c",
    "backends/x86_64_corenote.c",
]

# common-reloc.c does `#include RELOC_TYPES` -> "<arch>_reloc.def"; the 17
# *_reloc.def files are EXTRA_DIST (shipped), textually #included per backend
# and added to textual_hdrs below.
EBL_TEXTUAL_ONLY = [
    "backends/common-reloc.c",
    "backends/linux-core-note.c",
    "backends/x86_corenote.c",
]

EBL_TEXTUAL_HDRS = EBL_TEXTUAL_ONLY + EBL_CORENOTE_DUAL + glob(["backends/*_reloc.def"])

# i386_disasm.c is compiled standalone here (32-bit disassembler) and is also
# textually #included by x86_64_disasm.c (compiled in :dw). It pulls the
# mnemonic tables via i386_mne.h. The disassembler has no libdw references.
cc_library(
    name = "cpu",
    srcs = ["libcpu/i386_disasm.c"],
    copts = EU_COPTS,
    linkstatic = True,
    textual_hdrs = [
        ":i386_mnemonics",
        ":x86_64_mnemonics",
    ],
    deps = [":internal_hdrs"],
)

cc_library(
    name = "ebl_corenote",
    srcs = EBL_CORENOTE_DUAL,
    copts = EU_COPTS,
    linkstatic = True,
    textual_hdrs = EBL_TEXTUAL_HDRS,
    visibility = ["//visibility:private"],
    deps = [":internal_hdrs"],
)

# -------- libdw + libdwfl + libdwelf + libebl + backends + libcpu ------------
# libdw and libebl/backends are mutually dependent (backend retval/cfi code
# calls dwarf_peel_type / dwarf_aggregate_size, while libdw dispatches through
# the EBL backends). Upstream resolves this by linking libebl + the backends
# into libdw.so with --whole-archive. With static cc_library archives a
# two-target cycle cannot be resolved in a single link pass, so libebl, the
# backends, libcpu and libeu are compiled into this one :dw archive — matching
# the upstream libdw.so composition.
#
# bzip2.c / lzma.c / zstd.c are autoconf-conditional (BZLIB/LZMA/ZSTD) and
# omitted; gzip.c provides the zlib path consumed for SHF_COMPRESSED debug
# sections.
cc_library(
    name = "dw",
    srcs = glob(["libdw/*.c", "libdwelf/*.c", "libebl/*.c"]) + glob(
        ["libdwfl/*.c"],
        exclude = [
            "libdwfl/bzip2.c",
            "libdwfl/lzma.c",
            "libdwfl/zstd.c",
        ],
    ) + glob(
        ["backends/*.c"],
        # The dual-role *_corenote.c (EBL_CORENOTE_DUAL) are compiled in
        # :ebl_corenote and also #included by their wider sibling, so they are
        # textual_hdrs here, not srcs.
        exclude = EBL_TEXTUAL_ONLY + EBL_CORENOTE_DUAL,
    ) + [
        # libcpu disasm: i386_disasm.c is compiled in :cpu (and #included by
        # x86_64_disasm.c), so only the other three are compiled here.
        "libcpu/x86_64_disasm.c",
        "libcpu/bpf_disasm.c",
        "libcpu/riscv_disasm.c",
        "lib/xasprintf.c",
        "lib/xstrdup.c",
        "lib/xstrndup.c",
        "lib/xmalloc.c",
        "lib/next_prime.c",
        "lib/crc32.c",
        "lib/crc32_file.c",
        "lib/color.c",
        "lib/error.c",
        "lib/printversion.c",
    ],
    copts = EU_COPTS,
    linkopts = ["-lpthread"],
    linkstatic = True,
    # Cross-directory / per-arch textual .c includes: libdwfl_crc32{,_file}.c
    # pull ../lib/crc32{,_file}.c; x86_64_disasm.c pulls i386_disasm.c + the
    # mnemonics; the backends pull common-reloc.c / *_reloc.def / the dual
    # *_corenote.c / x86_corenote.c.
    textual_hdrs = [
        "lib/crc32.c",
        "lib/crc32_file.c",
        "libcpu/i386_disasm.c",
        ":i386_mnemonics",
        ":x86_64_mnemonics",
    ] + EBL_TEXTUAL_HDRS,
    visibility = ["//visibility:public"],
    deps = [":internal_hdrs", ":elf", ":cpu", ":ebl_corenote", "@zlib_src//:z"],
)

# -------- public headers for downstream consumers (dwarves) ------------------
# dwarves includes <elfutils/libdwfl.h>, <elfutils/version.h>, <dwarf.h> and
# (flat) <gelf.h>/<libelf.h>. The elfutils/-prefixed set is exposed via a
# generated copy under an elfutils/ subdir; the flat headers come from the
# libdw/libelf include dirs.
genrule(
    name = "elfutils_pub_hdrs",
    srcs = [
        "libdwfl/libdwfl.h",
        "version.h",
        "libdw/libdw.h",
    ],
    outs = [
        "pub/elfutils/libdwfl.h",
        "pub/elfutils/version.h",
        "pub/elfutils/libdw.h",
    ],
    cmd = "mkdir -p $(RULEDIR)/pub/elfutils && " +
          "cp $(location libdwfl/libdwfl.h) $(RULEDIR)/pub/elfutils/libdwfl.h && " +
          "cp $(location version.h) $(RULEDIR)/pub/elfutils/version.h && " +
          "cp $(location libdw/libdw.h) $(RULEDIR)/pub/elfutils/libdw.h",
)

cc_library(
    name = "headers_pub",
    hdrs = [
        ":elfutils_pub_hdrs",
        "libdw/dwarf.h",
        "libdw/known-dwarf.h",
        "libdw/libdw.h",
        "libelf/libelf.h",
        "libelf/gelf.h",
        "libelf/elf.h",
        "libdwfl/libdwfl.h",
    ],
    includes = [
        "pub",
        "libdw",
        "libelf",
        "libdwfl",
    ],
    visibility = ["//visibility:public"],
)
""",
    sha256 = "8e00a3a9b5f04bc1dc273ae86281d2d26ed412020b391ffcc23198f10231d692",
    strip_prefix = "elfutils-0.190",
    urls = ["https://sourceware.org/elfutils/ftp/0.190/elfutils-0.190.tar.bz2"],
)

# ----------------------------------------------------------------------------
# libbpf 1.3.0 — hermetic native Bazel host library for pahole's BTF encoder.
#
# dwarves bundles libbpf as a git submodule (lib/bpf); the release tarball does
# not ship submodule contents, so libbpf is fetched and built separately here
# (a version compatible with dwarves v1.27). libbpf depends on libelf and zlib.
# It is a plain set of .c files with no generated config header
# (src/libbpf_version.h is shipped). The bundled include/uapi/linux/*.h supply
# the newer kernel UAPI (e.g. struct btf_enum64) and include/linux/*.h supply
# the kernel-compat wrappers; both are PRIVATE to libbpf's own TUs. Only the
# install layout — public headers under a bpf/ prefix and the uapi headers —
# is re-exported to dwarves, which must NOT see include/linux/types.h (it would
# clash with dwarves' own list.h struct list_head).
# ----------------------------------------------------------------------------
http_archive(
    name = "libbpf_src",
    build_file_content = """
load("@rules_cc//cc:cc_library.bzl", "cc_library")

# libbpf's private compile-time headers staged into a virtual include root via
# strip_include_prefix. They are listed in :bpf's own srcs (so they are present
# in the sandbox) and the include dirs are supplied through :bpf's NON-PROPAGATING
# copts below — deliberately NOT via the `includes` attribute, because that would
# leak include/linux/types.h (which defines `struct list_head`) onto every
# consumer's search path and clash with dwarves' own list.h. pahole instead
# resolves <linux/types.h> from the sysroot (uapi, no list_head) and gets only
# the newer <linux/btf.h> from the safe :bpf_uapi_hdrs (include/uapi).
filegroup(
    name = "bpf_private_hdrs",
    srcs = glob([
        "include/*.h",
        "include/uapi/linux/*.h",
        "include/linux/*.h",
        "include/asm/*.h",
        "src/*.h",
    ]),
    visibility = ["//visibility:private"],
)

cc_library(
    name = "bpf",
    srcs = glob(["src/*.c"]) + [":bpf_private_hdrs"],
    copts = [
        "-D_GNU_SOURCE",
        "-D_LARGEFILE64_SOURCE",
        "-D_FILE_OFFSET_BITS=64",
        "-std=gnu89",
        "-Wno-error",
        "-Wno-unused-parameter",
        "-Wno-sign-compare",
        # Non-propagating include dirs (copts, not `includes`) so libbpf's
        # private include/linux wrappers never reach consumers like pahole.
        "-Iexternal/sonic-build-infra++_repo_rules2+libbpf_src/src",
        "-Iexternal/sonic-build-infra++_repo_rules2+libbpf_src/include",
        "-Iexternal/sonic-build-infra++_repo_rules2+libbpf_src/include/uapi",
    ],
    linkstatic = True,
    visibility = ["//visibility:public"],
    deps = [
        "@elfutils_src//:elf",
        "@zlib_src//:z",
    ],
)

# Public consumer headers under a bpf/ prefix (the install_headers layout).
# Exposed to dwarves as <bpf/btf.h>, <bpf/libbpf.h>, ...
cc_library(
    name = "bpf_pub_hdrs",
    hdrs = glob(["src/*.h"]),
    strip_include_prefix = "src",
    include_prefix = "bpf",
    visibility = ["//visibility:private"],
)

# The bundled uapi (include/uapi) for the newer <linux/btf.h> (struct
# btf_enum64). include/linux (the kernel-compat wrapper headers) is deliberately
# NOT on the include path — it would clash with dwarves' own list.h.
cc_library(
    name = "bpf_uapi_hdrs",
    hdrs = glob(["include/uapi/linux/*.h"]),
    includes = ["include/uapi"],
    visibility = ["//visibility:private"],
)

cc_library(
    name = "bpf_hdrs",
    visibility = ["//visibility:public"],
    deps = [":bpf_pub_hdrs", ":bpf_uapi_hdrs"],
)
""",
    sha256 = "11db86acd627e468bc48b7258c1130aba41a12c4d364f78e184fd2f5a913d861",
    strip_prefix = "libbpf-1.3.0",
    urls = ["https://github.com/libbpf/libbpf/archive/refs/tags/v1.3.0.tar.gz"],
)

