# Keep bazel_compatibility in sync with sonic-buildimage's .bazelversion.
module(
    name = "sonic-build-infra",
    version = "0.0.0",
    bazel_compatibility = [
        ">=8.5.1",
        "<=8.6.0",
    ],
)

bazel_dep(name = "swig", version = "4.1.0")
bazel_dep(name = "protobuf", version = "29.0")
bazel_dep(name = "rules_cc", version = "0.2.14")
bazel_dep(name = "rules_python", version = "1.7.0")
bazel_dep(name = "aspect_rules_py", version = "1.8.4")
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "tar.bzl", version = "0.8.1")
# libarchive: linked into mke2fs (@e2fsprogs_src//:mke2fs) for `mke2fs -d
# <tarball>` direct tar->ext4 ingestion (HAVE_ARCHIVE_H direct-link mode).
bazel_dep(name = "libarchive", version = "3.8.1.bcr.2")

# @gawk: the sealed awk that //initramfs:defs.bzl and //tar:assert_tar.bzl take.
# gawk is already in the module graph (pulled transitively by rules_distroless
# and tar.bzl); this bazel_dep makes @gawk resolve to that module within this
# module's repo namespace, so the bare @gawk label in those rules works (root-
# module repos are not visible here). @gawk//:gawk is a prebuilt cc_binary.
bazel_dep(name = "gawk", version = "5.3.2.bcr.3")

# TODO(bazel-ready): Upgrade tar.bzl when the version with this commit releases.
git_override(
    module_name = "tar.bzl",
    commit = "9b76e660363ab2465d89d3aadbbc1f7afa02e65c",
    remote = "https://github.com/bazel-contrib/tar.bzl",
)

bazel_dep(name = "bazel_skylib", version = "1.8.2")
bazel_dep(name = "bazel_lib", version = "3.1.1")

# Host-tool toolchains used by //kernel:host_tools.bzl (flex/bison/m4/perl).
# The @flex/@bison/@m4/@perl repos + toolchain registration are provided by the
# consuming root module; these deps make the @rules_*//...:toolchain_type labels
# resolvable from within @sonic_build_infra.
bazel_dep(name = "rules_flex", version = "0.4")
bazel_dep(name = "rules_bison", version = "0.4")
bazel_dep(name = "rules_m4", version = "0.3")
bazel_dep(name = "rules_perl", version = "1.1.0")

bazel_dep(name = "rules_distroless", version = "0.0.0")
git_override(
    module_name = "rules_distroless",
    commit = "815b4b3",
    remote = "https://github.com/songqing-sq/rules_distroless.git",
)

fetch_gcc = use_repo_rule("//toolchains/gcc:gcc.bzl", "fetch_gcc")

fetch_gcc(
    name = "gcc-linux-x86_64",
    integrity = "sha256-CzZeXaRR9cetxZT5Z4hdcYH/bRh9YImkvPNvlUvzzPk=",
    urls = ["https://github.com/f0rmiga/gcc-builds/releases/download/18082025/gcc-toolchain-14.3.0-x86_64.tar.xz"],
)

fetch_gcc(
    name = "gcc-linux-aarch64",
    integrity = "sha256-ew4lEzqY1EtkipJboR9ko63EcOh2aK+Aziw684nr6b4=",
    urls = ["https://github.com/f0rmiga/gcc-builds/releases/download/18082025/gcc-toolchain-12.5.0-aarch64.tar.xz"],
    prefix = "aarch64-linux",
)

register_toolchains(
    "//toolchains/gcc:linux_x86_64",
    "//toolchains/gcc:cross_aarch64",
)

apt = use_extension("@rules_distroless//apt:extensions.bzl", "apt")

# NOTE: sources are keyed by suite in rules_distroless, so the same suite must
# declare every architecture in one sources_list. Splitting amd64/arm64 into
# separate tags would let the later one overwrite the former, and since
# apt.install derives target architectures from the suite's sources, the
# dependency set would collapse onto a single (the last-declared) architecture.
apt.sources_list(
    architectures = ["amd64", "arm64"],
    components = ["main"],
    suites = ["trixie", "trixie-updates"],
    uris = ["https://snapshot.debian.org/archive/debian/20260409T202916Z"],
)
apt.sources_list(
    architectures = ["amd64", "arm64"],
    components = ["main"],
    suites = ["trixie-security"],
    uris = ["https://snapshot.debian.org/archive/debian-security/20260409T182303Z"],
)

# Single multi-arch sysroot. The generated @sysroot-trixie//:directory
# select()s the right packages from the target platform's CPU constraint, so
# one set serves both the x86_64 and aarch64 cc toolchains.
apt.install(
    dependency_set = "sysroot-trixie",
    packages = ["libc6-dev", "libstdc++6", "linux-libc-dev"],
    suites = ["trixie", "trixie-updates", "trixie-security"],
)

use_repo(apt, "sysroot-trixie")

# pip hub for build-time Python tools (e.g. the jinja2 renderer). Declared in
# this module so targets under @sonic_build_infra can depend on @pip_tools//...
# without relying on the root module's separate "pip" hub, which is not visible
# here. Uses the same aspect_rules_py uv extension as docker-base-bookworm.
uv = use_extension("@aspect_rules_py//uv/unstable:extension.bzl", "uv")
uv.declare_hub(hub_name = "pip_tools")
uv.declare_venv(
    hub_name = "pip_tools",
    venv_name = "default",
)
uv.lockfile(
    src = "//jinja2:uv.lock",
    hub_name = "pip_tools",
    venv_name = "default",
)

# Build-time pyang (YANG codegen) runner. Separate venv on the same pip_tools
# hub so @sonic_build_infra//pyang:pyang can depend on @pip_tools//pyang.
uv.declare_venv(
    hub_name = "pip_tools",
    venv_name = "pyang",
)
uv.lockfile(
    src = "//pyang:uv.lock",
    hub_name = "pip_tools",
    venv_name = "pyang",
)
use_repo(uv, "pip_tools")

