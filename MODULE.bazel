# ----------------------------------------------------------------------------
# libbpf 1.3.0 — hermetic native Bazel host library for pahole's BTF encoder.
#
# dwarves bundles libbpf as a git submodule (lib/bpf); the release tarball does
# not ship submodule contents, so libbpf is fetched and built separately here
# (a version compatible with dwarves v1.27). libbpf depends on libelf and zlib.
# It is a plain set of .c files with no generated config header
# (src/libbpf_version.h is shipped). The bundled include/uapi/linux/*.h supply
# the newer kernel UAPI (e.g. struct btf_enum64) and include/linux/*.h supply
# the kernel-compat wrappers; both are PRIVATE to libbpf's own TUs. Only the
# install layout — public headers under a bpf/ prefix and the uapi headers —
# is re-exported to dwarves, which must NOT see include/linux/types.h (it would
# clash with dwarves' own list.h struct list_head).
# ----------------------------------------------------------------------------
http_archive(
    name = "libbpf_src",
    build_file_content = """
load("@rules_cc//cc:cc_library.bzl", "cc_library")

# libbpf's private compile-time headers staged into a virtual include root via
# strip_include_prefix. They are listed in :bpf's own srcs (so they are present
# in the sandbox) and the include dirs are supplied through :bpf's NON-PROPAGATING
# copts below — deliberately NOT via the `includes` attribute, because that would
# leak include/linux/types.h (which defines `struct list_head`) onto every
# consumer's search path and clash with dwarves' own list.h. pahole instead
# resolves <linux/types.h> from the sysroot (uapi, no list_head) and gets only
# the newer <linux/btf.h> from the safe :bpf_uapi_hdrs (include/uapi).
filegroup(
    name = "bpf_private_hdrs",
    srcs = glob([
        "include/*.h",
        "include/uapi/linux/*.h",
        "include/linux/*.h",
        "include/asm/*.h",
        "src/*.h",
    ]),
    visibility = ["//visibility:private"],
)

cc_library(
    name = "bpf",
    srcs = glob(["src/*.c"]) + [":bpf_private_hdrs"],
    copts = [
        "-D_GNU_SOURCE",
        "-D_LARGEFILE64_SOURCE",
        "-D_FILE_OFFSET_BITS=64",
        "-std=gnu89",
        "-Wno-error",
        "-Wno-unused-parameter",
        "-Wno-sign-compare",
        # Non-propagating include dirs (copts, not `includes`) so libbpf's
        # private include/linux wrappers never reach consumers like pahole.
        "-Iexternal/sonic-build-infra++_repo_rules2+libbpf_src/src",
        "-Iexternal/sonic-build-infra++_repo_rules2+libbpf_src/include",
        "-Iexternal/sonic-build-infra++_repo_rules2+libbpf_src/include/uapi",
    ],
    linkstatic = True,
    visibility = ["//visibility:public"],
    deps = [
        "@elfutils_src//:elf",
        "@zlib_src//:z",
    ],
)

# Public consumer headers under a bpf/ prefix (the install_headers layout).
# Exposed to dwarves as <bpf/btf.h>, <bpf/libbpf.h>, ...
cc_library(
    name = "bpf_pub_hdrs",
    hdrs = glob(["src/*.h"]),
    strip_include_prefix = "src",
    include_prefix = "bpf",
    visibility = ["//visibility:private"],
)

# The bundled uapi (include/uapi) for the newer <linux/btf.h> (struct
# btf_enum64). include/linux (the kernel-compat wrapper headers) is deliberately
# NOT on the include path — it would clash with dwarves' own list.h.
cc_library(
    name = "bpf_uapi_hdrs",
    hdrs = glob(["include/uapi/linux/*.h"]),
    includes = ["include/uapi"],
    visibility = ["//visibility:private"],
)

cc_library(
    name = "bpf_hdrs",
    visibility = ["//visibility:public"],
    deps = [":bpf_pub_hdrs", ":bpf_uapi_hdrs"],
)
""",
    sha256 = "11db86acd627e468bc48b7258c1130aba41a12c4d364f78e184fd2f5a913d861",
    strip_prefix = "libbpf-1.3.0",
    urls = ["https://github.com/libbpf/libbpf/archive/refs/tags/v1.3.0.tar.gz"],
)

