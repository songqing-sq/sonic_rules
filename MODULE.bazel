        "gnu/printf-args.c",
        "gnu/printf-parse.c",
        "gnu/progname.c",
        "gnu/quotearg.c",
        ":gnu_safe_read_tu",
        "gnu/safe-write.c",
        "gnu/save-cwd.c",
        "gnu/savedir.c",
        "gnu/setlocale_null.c",
        "gnu/stat-time.c",
        "gnu/stripslash.c",
