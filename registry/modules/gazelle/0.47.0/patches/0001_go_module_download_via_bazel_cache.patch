+def escape_module_path(path):
+    """Escape a Go module path for GOPROXY URLs (uppercase -> !lowercase)."""
+    result = []
+    for i in range(len(path)):
+        c = path[i]
+        if c >= "A" and c <= "Z":
+            result.append("!" + c.lower())
+        else:
+            result.append(c)
+    return "".join(result)
+
+def build_goproxy_zip_url(goproxy, module_path, version):
+    """Construct the GOPROXY zip download URL for a Go module."""
+    proxy = "https://proxy.golang.org"
+    for part in goproxy.replace("|", ",").split(","):
+        candidate = part.strip()
+        if candidate and candidate not in ("direct", "off"):
+            proxy = candidate
+            break
+    escaped = escape_module_path(module_path)
+    return proxy.rstrip("/") + "/" + escaped + "/@v/" + version + ".zip"
+
