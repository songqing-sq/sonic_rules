diff --git a/cmd/fetch_repo/module_zip.go b/cmd/fetch_repo/module_zip.go
new file mode 100644
index 0000000..34d6ab7
--- /dev/null
+++ b/cmd/fetch_repo/module_zip.go
@@ -0,0 +1,71 @@
+package main
+
+import (
+	"archive/zip"
+	"fmt"
+	"io"
+	"os"
+	"path/filepath"
+	"strings"
+
+	"golang.org/x/mod/sumdb/dirhash"
+)
+
+func fetchModuleFromZip(dest, importpath, version, sum, zipPath string) error {
+	prefix := importpath + "@" + version + "/"
+
+	r, err := zip.OpenReader(zipPath)
+	if err != nil {
+		return fmt.Errorf("opening module zip %s: %w", zipPath, err)
+	}
+	defer r.Close()
+
+	for _, f := range r.File {
+		if !strings.HasPrefix(f.Name, prefix) {
+			continue
+		}
+		relPath := strings.TrimPrefix(f.Name, prefix)
+		if relPath == "" {
+			continue
+		}
+		target := filepath.Join(dest, relPath)
+
+		if f.FileInfo().IsDir() {
+			if err := os.MkdirAll(target, 0o777); err != nil {
+				return err
+			}
+			continue
+		}
+
+		if err := os.MkdirAll(filepath.Dir(target), 0o777); err != nil {
+			return err
+		}
+		out, err := os.OpenFile(target, os.O_WRONLY|os.O_CREATE|os.O_TRUNC, f.Mode()|0o644)
+		if err != nil {
+			return err
+		}
+		in, err := f.Open()
+		if err != nil {
+			out.Close()
+			return err
+		}
+		_, err = io.Copy(out, in)
+		in.Close()
+		out.Close()
+		if err != nil {
+			return err
+		}
+	}
+	r.Close()
+
+	os.Remove(zipPath)
+
+	repoSum, err := dirhash.HashDir(dest, importpath+"@"+version, dirhash.Hash1)
+	if err != nil {
+		return fmt.Errorf("computing dir hash: %w", err)
+	}
+	if repoSum != sum {
+		return fmt.Errorf("module %s@%s: got sum %s; expected %s", importpath, version, repoSum, sum)
+	}
+	return nil
+}
