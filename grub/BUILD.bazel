# ---------------------------------------------------------------------------
# i386-pc platform images — built from GRUB 2.06 source with gcc -m32.
#
# boot.img           512 B  raw binary  (MBR boot sector)
# diskboot.img       512 B  raw binary  (first sector of core.img)
# lzma_decompress.img ~3 KB raw binary  (LZMA decompressor stub)
# kernel.img         ~31 KB stripped ELF (GRUB kernel)
#
# grub-mkimage reads kernel.img + diskboot.img + lzma_decompress.img;
# grub-bios-setup reads boot.img and writes it to the MBR.
# ---------------------------------------------------------------------------
genrule(
    name = "build_platform_imgs",
    srcs = [
        "@grub_src//:platform_img_srcs",
        # Explicit dep so $(location) can derive @grub_src root path.
        "@grub_src//:grub-core/boot/i386/pc/boot.S",
        "generated/config.h",
        "generated/symlist.c",
    ],
    outs = [
        "boot.img",
        "diskboot.img",
        "lzma_decompress.img",
        "kernel.img",
    ],
    cmd = """
        # Derive @grub_src root from any source file in that repo.
        BOOT_S=$(location @grub_src//:grub-core/boot/i386/pc/boot.S)
        GRUB_ROOT=$${BOOT_S%%/grub-core/boot/i386/pc/boot.S}

        # Config dir (contains config.h and symlist.c).
        CFG_H=$(location generated/config.h)
        CFG_DIR=$$(dirname $$CFG_H)

        $(location build_platform_imgs.sh) \
            "$$GRUB_ROOT" "$$CFG_DIR" \
            $(location boot.img) \
            $(location diskboot.img) \
            $(location lzma_decompress.img) \
            $(location kernel.img)
    """,
    tools = ["build_platform_imgs.sh"],
    # gcc -m32 only works on x86_64 hosts; arm64 hosts cannot produce
    # i386-pc platform images (and KVM disk images are x86-only anyway).
    target_compatible_with = ["@platforms//cpu:x86_64"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "platform_imgs",
    srcs = [
        ":boot.img",
        ":diskboot.img",
        ":kernel.img",
        ":lzma_decompress.img",
    ],
    visibility = ["//visibility:public"],
)

