"""GRUB 2.06 host tools and i386-pc platform images.

Host tools (grub-mkimage, grub-bios-setup) are built from source as
cc_binary targets. The i386-pc platform images (boot.img, kernel.img,
diskboot.img, lzma_decompress.img) are built from @grub_src assembly/C
source via a genrule that invokes build_platform_imgs.sh with gcc -m32.

Source .c files come from @grub_src (http_archive). Pre-generated files
(config.h, config-util.h, bison/flex output, gnulib headers,
libgrub_a_init.c, symlist.c) are checked into //grub/generated/ -- they
are fixed for GRUB 2.06 on x86_64 Linux (glibc/bookworm).

The libraries are split into multiple cc_library targets to avoid Bazel
object-file basename collisions (e.g. multiple misc.c, getroot.c,
hostdisk.c from different GRUB subdirectories).
"""

load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

# Expose the grub-bios-setup mountinfo patch as a label so the @grub_src
# http_archive in MODULE.bazel can reference it via `patches`. The patch
# makes grub-bios-setup fall back to the destination disk image as the root
# device when its --directory has no real backing block device (overlayfs /
# tmpfs in the Bazel sandbox), instead of aborting on /proc/self/mountinfo.
exports_files(["grub-bios-setup-no-mountinfo.patch"])

# ---------------------------------------------------------------------------
# Generated headers
# ---------------------------------------------------------------------------
# Config + parser headers (safe to use globally; no system-header shadowing).
cc_library(
    name = "generated_hdrs",
    hdrs = [
        "generated/config.h",
        "generated/config-util.h",
        "generated/grub_script.tab.h",
        "generated/grub_script.yy.h",
    ],
    includes = ["generated"],
)

# Gnulib generated headers (override system <stdio.h>, <unistd.h>, etc.
# via #include_next). Only the :gnulib cc_library should depend on this;
# propagating these -isystem paths to other targets causes #include_next
# collisions with posix_wrap or other header-shadowing schemes.
cc_library(
    name = "gnulib_gen_hdrs",
    hdrs = glob(["generated/gnulib/**/*.h"]),
    includes = ["generated/gnulib"],
)

# ---------------------------------------------------------------------------
# Common compilation flags (from make -n output)
# ---------------------------------------------------------------------------
COMMON_COPTS = [
    "-DHAVE_CONFIG_H",
    "-DGRUB_UTIL=1",
    '-DGRUB_FILE=\'"grub"\'',
    "-D_FILE_OFFSET_BITS=64",
    "-std=gnu99",
    "-fno-builtin-gettext",
    "-Wno-error",
    "-Wno-unused-parameter",
    "-Wno-sign-compare",
    "-Wno-implicit-fallthrough",
    "-Wno-unused-result",
    "-Wno-unused-but-set-variable",
    "-Wno-missing-field-initializers",
    "-Wno-deprecated-declarations",
    "-Wno-undef",
    "-Wno-redundant-decls",
    "-Wno-old-style-definition",
    "-Wno-type-limits",
    "-Wno-format",
    "-Wno-missing-prototypes",
    "-Wno-missing-declarations",
    "-Wno-cast-align",
    "-Wno-nested-externs",
    "-Wno-shadow",
    "-Wno-address",
    "-Wno-strict-aliasing",
]

COMMON_DEPS = [
    ":generated_hdrs",
    "@grub_src//:grub_hdrs",
    "@grub_src//:gnulib_src_hdrs",
    "@grub_src//:textual_includes",
]

