# Stable alias, mirroring disk_image:{mke2fs,sgdisk}. Consumers (squashfs/rootfs
# rules, onie_installer) reference //tar:tar rather than @tar_src internals.
native_binary(
    name = "tar",
    src = ":tar_bin",
    out = "tar",
    visibility = ["//visibility:public"],
)
