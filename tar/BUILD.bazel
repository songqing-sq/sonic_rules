"""Hermetic GNU tar 1.35, built from @tar_src with native cc rules.

Replaces the host `tar` in squashfs/rootfs extraction (needs
--keep-directory-symlink + setuid-preserving -p) and onie_mk packing (-h).

The cc_binary lives here (not in @tar_src's build_file_content) so it can depend
on :gen_headers -- config.h plus 42 gnulib substitute headers (41 under gen/gnu,
1 under gen/lib) that ./configure generates from .in.h templates. Those were
captured once against this repo's gcc-12.5.0 + @sysroot-bookworm toolchain and
committed under gen/; regenerating them is the only step that needs ./configure
(never at build time).
"""

load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@bazel_skylib//rules:native_binary.bzl", "native_binary")

package(default_visibility = ["//visibility:public"])

# config.h + the 41 generated gnulib headers (gen/), exposed via three include
# roots so the angle-bracket includes in the sources resolve:
#   includes=["gen"]     -> <config.h>
#   includes=["gen/gnu"] -> gnulib's <stdio.h>, <getopt.h>, <configmake.h>, <sys/stat.h>...
#   includes=["gen/lib"] -> <rmt-command.h>
# No upstream header shares a name with a generated one, so there is no shadowing
# ambiguity (the one exception, stddef.h vs gcc's builtin, is handled in COPTS).
cc_library(
    name = "gen_headers",
    hdrs = glob(["gen/**/*.h"]),  # includes gen/config.h
    includes = ["gen", "gen/gnu", "gen/lib"],
    visibility = ["//visibility:public"],
)

# COPTS: -DHAVE_CONFIG_H selects config.h; the warning suppressions keep gnulib's
# portability code from failing the build under gcc-12 -Werror-free defaults.
#
# -Dunreachable: gcc-12 emits a call to the C23 `unreachable` library function at
# the tail of _Noreturn functions whose body calls a non-noreturn callee (e.g.
# error()), so gnulib's error.h does `(status)!=0 ? unreachable() : 0`. gnulib's
# own gen/gnu/stddef.h #defines unreachable()->__builtin_unreachable() under
# _GL_HAS_BUILTIN_UNREACHABLE, but that header cannot win over gcc's builtin
# stddef.h: the toolchain emits its include dir as `-isystem` (defs.bzl:189) and
# cc_library.includes also emit `-isystem` but later, so gcc's stddef.h (which
# lacks unreachable) shadows gnulib's. Pre-defining the macro here yields the
# exact expansion gnulib's stddef.h would (its `#ifndef unreachable` then no-ops)
# -- not a bypass, the same __builtin_unreachable() code, just won early.
TAR_COPTS = [
    "-DHAVE_CONFIG_H",
    "-Dunreachable()=__builtin_unreachable()",
    "-Wno-implicit-fallthrough",
    "-Wno-unused-parameter",
    "-Wno-sign-compare",
    "-Wno-missing-field-initializers",
    "-Wno-unused-but-set-variable",
    "-Wno-format-truncation",
    "-Wno-stringop-truncation",
    "-Wno-deprecated-declarations",
]

